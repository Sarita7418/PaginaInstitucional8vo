<!-- Dots de navegación lateral -->
<div id="section-nav">
  <button class="snav-dot active" data-i="0" aria-label="Ir a sección 1"></button>
  <button class="snav-dot" data-i="1" aria-label="Ir a sección 2"></button>
  <button class="snav-dot" data-i="2" aria-label="Ir a sección 3"></button>
  <button class="snav-dot" data-i="3" aria-label="Ir a sección 4"></button>
</div>
<div id="kb-hint">
  <div class="kb-key">ReP</div>
  <div class="kb-key">AvP</div>
</div>

<script>
  // ========== REVEAL ANIMATIONS ==========
  const revealObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          revealObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12, rootMargin: '0px 0px -30px 0px' }
  );
  document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

  // ========== FEATURE TABS INTERACTIVITY ==========
  const panels     = document.querySelectorAll('.feat-panel');
  const tabs       = document.querySelectorAll('.feat-tab');
  const dots       = document.querySelectorAll('.feat-dot');
  const prevBtn    = document.getElementById('feat-prev');
  const nextBtn    = document.getElementById('feat-next');
  const autoplayBtn = document.getElementById('feat-autoplay-btn');
  let current      = 0;

  const AUTOPLAY_DELAY = 4500;
  let autoplayTimer: ReturnType<typeof setInterval> | null = null;
  let autoplayPaused = false;
  let progressRafId: number | null = null;
  let progressStart: number | null = null;

  function startProgressBar() {
    const activeDot = dots[current] as HTMLElement;
    const bar = activeDot.querySelector('.feat-dot-progress') as HTMLElement;
    if (!bar) return;
    dots.forEach(d => {
      const b = d.querySelector('.feat-dot-progress') as HTMLElement;
      if (b) b.style.width = '0%';
    });
    progressStart = null;
    if (progressRafId) cancelAnimationFrame(progressRafId);
    function animateBar(ts: number) {
      if (!progressStart) progressStart = ts;
      const elapsed = ts - progressStart;
      const pct = Math.min((elapsed / AUTOPLAY_DELAY) * 100, 100);
      bar.style.width = pct + '%';
      if (pct < 100) {
        progressRafId = requestAnimationFrame(animateBar);
      }
    }
    progressRafId = requestAnimationFrame(animateBar);
  }

  function stopProgressBar() {
    if (progressRafId) {
      cancelAnimationFrame(progressRafId);
      progressRafId = null;
    }
    dots.forEach(d => {
      const b = d.querySelector('.feat-dot-progress') as HTMLElement;
      if (b) b.style.width = '0%';
    });
  }

  function startAutoplay() {
    if (autoplayTimer) clearInterval(autoplayTimer);
    startProgressBar();
    autoplayTimer = setInterval(() => {
      if (!autoplayPaused) goTo(current + 1);
    }, AUTOPLAY_DELAY);
  }

  function stopAutoplay() {
    if (autoplayTimer) { clearInterval(autoplayTimer); autoplayTimer = null; }
    stopProgressBar();
  }

  function toggleAutoplay() {
    autoplayPaused = !autoplayPaused;
    const iconPause = autoplayBtn?.querySelector('.icon-pause') as HTMLElement;
    const iconPlay  = autoplayBtn?.querySelector('.icon-play') as HTMLElement;
    if (autoplayPaused) {
      stopAutoplay();
      if (iconPause) iconPause.style.display = 'none';
      if (iconPlay)  iconPlay.style.display  = '';
      autoplayBtn?.setAttribute('aria-label', 'Reanudar autoplay');
      autoplayBtn?.setAttribute('title', 'Reanudar autoplay');
    } else {
      if (iconPause) iconPause.style.display = '';
      if (iconPlay)  iconPlay.style.display  = 'none';
      autoplayBtn?.setAttribute('aria-label', 'Pausar autoplay');
      autoplayBtn?.setAttribute('title', 'Pausar autoplay');
      startAutoplay();
    }
  }

  autoplayBtn?.addEventListener('click', toggleAutoplay);

  let resumeTimer: ReturnType<typeof setTimeout> | null = null;

  function userInteracted() {
    if (autoplayPaused) return;
    stopAutoplay();
    if (resumeTimer) clearTimeout(resumeTimer);
    resumeTimer = setTimeout(() => {
      if (!autoplayPaused) startAutoplay();
    }, 8000);
  }

  function goTo(idx: number) {
    panels[current].classList.remove('active');
    tabs[current].classList.remove('active');
    dots[current].classList.remove('active');
    current = (idx + panels.length) % panels.length;
    panels[current].classList.add('active');
    tabs[current].classList.add('active');
    dots[current].classList.add('active');
    tabs[current].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    if (!autoplayPaused && autoplayTimer) startProgressBar();
  }

  tabs.forEach((tab, i) => {
    tab.addEventListener('click', () => { userInteracted(); goTo(i); });
  });
  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => { userInteracted(); goTo(i); });
  });
  prevBtn?.addEventListener('click', () => { userInteracted(); goTo(current - 1); });
  nextBtn?.addEventListener('click', () => { userInteracted(); goTo(current + 1); });

  let touchStartX = 0;
  const panelWrapper = document.querySelector('.feat-panel-wrapper');
  panelWrapper?.addEventListener('touchstart', (e: Event) => {
    touchStartX = (e as TouchEvent).changedTouches[0].screenX;
  }, { passive: true });
  panelWrapper?.addEventListener('touchend', (e: Event) => {
    const diff = touchStartX - (e as TouchEvent).changedTouches[0].screenX;
    if (Math.abs(diff) > 40) {
      userInteracted();
      goTo(diff > 0 ? current + 1 : current - 1);
    }
  }, { passive: true });

  const featShowcase = document.getElementById('features-section');
  featShowcase?.addEventListener('mouseenter', () => {
    if (!autoplayPaused && autoplayTimer) stopAutoplay();
  });
  featShowcase?.addEventListener('mouseleave', () => {
    if (!autoplayPaused) startAutoplay();
  });

  // ========== SECTION SCROLL NAV ==========
  const sections = Array.from(document.querySelectorAll('.w-section'));
  const snavDots = document.querySelectorAll('.snav-dot');
  let isScrolling = false;

  function getActiveSection() {
    const mid = window.innerHeight / 2;
    let closest = 0, closestDist = Infinity;
    sections.forEach((s, i) => {
      const rect = s.getBoundingClientRect();
      const dist = Math.abs(rect.top + rect.height / 2 - mid);
      if (dist < closestDist) { closestDist = dist; closest = i; }
    });
    return closest;
  }

  function scrollToSection(idx: number) {
    if (idx < 0 || idx >= sections.length || isScrolling) return;
    isScrolling = true;
    const headerH = (document.querySelector('header') as HTMLElement)?.offsetHeight || 0;
    const top = sections[idx].getBoundingClientRect().top + window.scrollY - headerH;
    window.scrollTo({ top, behavior: 'smooth' });
    setTimeout(() => { isScrolling = false; }, 900);
  }

  (window as any).scrollToFeatures = () => scrollToSection(1);
  (window as any).scrollToSection = scrollToSection;

  document.addEventListener('keydown', (e) => {
    const activeTag = (document.activeElement as HTMLElement)?.tagName || '';
    if (['INPUT','TEXTAREA','SELECT'].includes(activeTag)) return;
    if (e.key === 'ArrowLeft')  { e.preventDefault(); userInteracted(); goTo(current - 1); }
    if (e.key === 'ArrowRight') { e.preventDefault(); userInteracted(); goTo(current + 1); }
    const isNext = e.key === 'ArrowDown' || e.key === 'PageDown' || (e.key === ' ' && !e.shiftKey);
    const isPrev = e.key === 'ArrowUp'   || e.key === 'PageUp'   || (e.key === ' ' && e.shiftKey);
    if (isNext) { e.preventDefault(); scrollToSection(getActiveSection() + 1); }
    if (isPrev) { e.preventDefault(); scrollToSection(getActiveSection() - 1); }
    if (e.key === 'Home') { e.preventDefault(); scrollToSection(0); }
    if (e.key === 'End')  { e.preventDefault(); scrollToSection(sections.length - 1); }
  });

  snavDots.forEach(dot => {
    dot.addEventListener('click', () => scrollToSection(Number((dot as HTMLElement).dataset.i)));
  });

  function updateSnavDots() {
    const active = getActiveSection();
    snavDots.forEach((d, i) => d.classList.toggle('active', i === active));
  }
  window.addEventListener('scroll', updateSnavDots, { passive: true });
  updateSnavDots();

  const showcaseObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        if (!autoplayTimer && !autoplayPaused) startAutoplay();
      } else {
        stopAutoplay();
      }
    });
  }, { threshold: 0.3 });

  if (featShowcase) showcaseObserver.observe(featShowcase);
</script>