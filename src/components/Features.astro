---
import './Features.css';

const features = [
  {
    id: 'audioguia',
    tag: 'Contexto Histórico',
    title: 'Audioguías Narrativas',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>`,
    desc: 'Wali te enviará una notificación al acercarte a un sitio turístico, activando audioguías inmersivas que te explicarán toda la historia y el contexto del lugar.',
    detail: 'Activación automática por geofencing · Descarga offline · Transcripción para personas con discapacidad auditiva',
    bg: '/images/calle_jaen.jpg',
    interfaz: '/images/interfaz1.png',
    color: 'var(--color-teal)'
  },
  {
    id: 'mapas',
    tag: 'Cartografía Avanzada',
    title: 'Mapas y Geolocalización',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/><line x1="9" y1="3" x2="9" y2="18"/><line x1="15" y1="6" x2="15" y2="21"/></svg>`,
    desc: 'Observa tu entorno con precisión. Encuentra sitios de interés, descubre rutas turísticas recomendadas y visualiza el mapa interactivo offline.',
    detail: 'POIs categorizados · Modo "Cerca de mí" · Rutas en tiempo real a pie o en transporte',
    bg: '/images/altiplano.jpg',
    interfaz: '/images/interfaz2.png',
    color: 'var(--color-green)'
  },
  {
    id: 'itinerarios',
    tag: 'Planificación a Medida',
    title: 'Itinerarios Inteligentes',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="8" y1="14" x2="10" y2="14"/><line x1="12" y1="14" x2="16" y2="14"/><line x1="8" y1="18" x2="10" y2="18"/></svg>`,
    desc: 'Dinos qué te gusta y nosotros armamos el plan. Escoge tus actividades y Wali generará un itinerario recomendado, completamente editable.',
    detail: 'IA personalizada · Drag & drop de actividades · Vista de calendario · Recálculo automático de tiempos',
    bg: '/images/valle_luna.jpg',
    interfaz: '/images/interfaz3.png',
    color: 'var(--color-orange)'
  },
  {
    id: 'asistente',
    tag: 'Atención 24/7',
    title: 'Asistente Inteligente',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
    desc: 'Tu guía paceño de bolsillo. Nuestro chatbot de IA está listo para hacerte recomendaciones de rutas y resolver dudas turísticas en tiempo real.',
    detail: 'Recomendaciones contextuales · Consultas culturales · Disponible en múltiples idiomas',
    bg: '/images/mirador_killi.jpg',
    interfaz: '/images/interfaz4.png',
    color: 'var(--color-teal)'
  },
  {
    id: 'gastronomia',
    tag: 'Sabores sin Riesgos',
    title: 'Decodificador Gastronómico',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2l1.5 1.5"/><path d="M7.5 2L9 3.5"/><path d="M12 2l1.5 1.5"/><path d="M2 12C2 6.5 6.5 2 12 2s10 4.5 10 10-4.5 10-10 10S2 17.5 2 12z"/><path d="M12 6v6l4 2"/></svg>`,
    desc: 'Apunta tu cámara al menú. Wali identificará el plato, mostrará sus ingredientes y preparación para prevenir reacciones alérgicas y sorpresas.',
    detail: 'Escaneo OCR de menús · Enciclopedia de platos típicos · Alerta de alérgenos · Traducción instantánea',
    bg: '/images/mercado_ancestral.jpg',
    interfaz: '/images/interfaz5.png',
    color: 'var(--color-brown)'
  },
  {
    id: 'seguridad',
    tag: 'Exploración Segura',
    title: 'Seguridad y Tranquilidad',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    desc: 'Muévete con confianza. El mapa marca zonas de precaución y cuentas con un botón de pánico integrado para llamar a la policía en emergencias.',
    detail: 'Zonas de riesgo en mapa · Botón SOS · Alertas push · Ubicación compartida con contacto de confianza',
    bg: '/images/twanaku.jpg',
    interfaz: '/images/interfaz6.png',
    color: 'var(--color-green)'
  },
  {
    id: 'tarifas',
    tag: 'Economía Justa',
    title: 'Recomendador de Tarifas',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
    desc: 'Evita cobros excesivos. En una ciudad sin taxímetros, nuestra herramienta te calcula la tarifa recomendada para tu ruta de transporte.',
    detail: 'Calculadora de taxis · Precios de entradas a museos · Estimador de presupuesto diario',
    bg: '/images/Ciudad_de_La_Paz_de_noche.jpg',
    interfaz: '/images/interfaz7.png',
    color: 'var(--color-orange)'
  }
];
---

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;0,700;1,600;1,700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

<style>
  /* ===== SECCIÓN PRECIO TURISTA ===== */
  .s-publicidad {
    padding: 48px 3vw;
    background: #F2EDE4;
    position: relative;
    overflow: hidden;
    min-height: 100vh;
    display: flex;
    align-items: center;
    box-sizing: border-box;
  }

  /* Gradiente ambiental suave */
  .s-publicidad::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 50% at 75% 50%, rgba(29,158,117,0.08) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  /* ── Decoraciones SVG de turismo ── */

  /* Silueta de montaña (Illimani) — esquina inferior derecha */
  .pub-deco-mountain {
    position: absolute;
    bottom: 0;
    right: 0;
    width: 340px;
    opacity: 0.12;
    pointer-events: none;
    z-index: 0;
  }

  /* Teleférico — esquina superior izquierda */
  .pub-deco-cable {
    position: absolute;
    top: 24px;
    left: 0;
    width: 260px;
    opacity: 0.13;
    pointer-events: none;
    z-index: 0;
  }

  /* Patrón wiphala / trama geométrica — fondo izquierdo */
  .pub-deco-pattern {
    position: absolute;
    top: 50%;
    left: -60px;
    transform: translateY(-50%);
    width: 200px;
    height: 200px;
    opacity: 0.04;
    pointer-events: none;
    z-index: 0;
  }

  /* Línea de altiplano — separador superior decorativo */
  .pub-deco-topline {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, transparent 0%, #1D9E75 30%, #5DCAA5 60%, transparent 100%);
    z-index: 1;
  }

  /* Textura de puntos suave sobre el fondo crema */
  .s-publicidad::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(29,158,117,0.08) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
    z-index: 0;
  }

  /* ── Grid interior ── */
  .pub-inner {
    max-width: 1400px;
    width: 100%;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: start;
    position: relative;
    z-index: 1;
  }

  .pub-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #1D9E75;
    margin-bottom: 16px;
  }

  .pub-eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #5DCAA5;
    animation: pub-blink 2s ease-in-out infinite;
  }

  @keyframes pub-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .pub-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.9rem, 3.6vw, 3rem);
    font-weight: 700;
    line-height: 1.15;
    color: #1a2e25;
    margin: 0 0 18px;
  }

  .pub-title em {
    font-style: italic;
    color: #1D9E75;
  }

  .pub-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    color: rgba(30,50,40,0.65);
    line-height: 1.75;
    margin: 0 0 20px;
  }

  .pub-price-block {
    display: flex;
    align-items: flex-end;
    gap: 14px;
    margin-bottom: 8px;
  }

  .pub-price-main {
    font-family: 'Cormorant Garamond', serif;
    font-size: 4rem;
    font-weight: 700;
    line-height: 1;
    color: #1a2e25;
  }

  .pub-price-meta {
    display: flex;
    flex-direction: column;
    padding-bottom: 10px;
    gap: 3px;
  }

  .pub-price-currency {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: #1D9E75;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .pub-price-period {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.78rem;
    color: rgba(30,50,40,0.5);
  }

  .pub-price-note {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.78rem;
    color: rgba(30,50,40,0.45);
    margin: 0 0 30px;
  }

  /* Insignias de turismo debajo del precio */
  .pub-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 28px;
  }

  .pub-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    border: 1px solid rgba(29,158,117,0.3);
    border-radius: 100px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.7rem;
    font-weight: 500;
    color: rgba(30,50,40,0.65);
    background: rgba(29,158,117,0.08);
  }

  .pub-badge svg {
    color: #5DCAA5;
    flex-shrink: 0;
  }

  .pub-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 30px;
    background: #1D9E75;
    color: #fff;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
  }

  .pub-cta-btn:hover {
    background: #0F6E56;
    transform: translateY(-2px);
  }

  .pub-cta-btn svg {
    transition: transform 0.2s;
  }

  .pub-cta-btn:hover svg {
    transform: translateX(3px);
  }

  /* ── Tarjeta derecha ── */
  .pub-features-card {
    background: #fff;
    border: 1px solid rgba(29,158,117,0.15);
    border-radius: 18px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    max-height: calc(100vh - 96px);
    box-shadow: 0 8px 40px rgba(30,50,40,0.1);
  }

  .pub-card-header {
    background: #1D9E75;
    padding: 20px 26px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .pub-card-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.65);
    margin: 0 0 4px;
  }

  .pub-card-title {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: #fff;
    margin: 0;
  }

  .pub-card-price-badge {
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 10px;
    padding: 8px 16px;
    text-align: center;
    flex-shrink: 0;
  }

  .pub-card-price-badge .amount {
    display: block;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: #fff;
    line-height: 1;
  }

  .pub-card-price-badge .period {
    display: block;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.62rem;
    color: rgba(255,255,255,0.7);
    margin-top: 2px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .pub-features-list {
    padding: 2px 0;
    overflow-y: auto;
    flex: 1;
    scrollbar-width: thin;
    scrollbar-color: rgba(29,158,117,0.3) transparent;
  }
  .pub-features-list::-webkit-scrollbar { width: 4px; }
  .pub-features-list::-webkit-scrollbar-track { background: transparent; }
  .pub-features-list::-webkit-scrollbar-thumb { background: rgba(29,158,117,0.3); border-radius: 2px; }

  .pub-feature-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 8px 20px;
    border-bottom: 1px solid rgba(30,50,40,0.07);
    transition: background 0.15s;
  }

  .pub-feature-item:last-child {
    border-bottom: none;
  }

  .pub-feature-item:hover {
    background: rgba(29,158,117,0.04);
  }

  .pub-feature-icon {
    width: 32px;
    height: 32px;
    border-radius: 7px;
    background: rgba(29,158,117,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: #5DCAA5;
  }

  .pub-feature-icon svg {
    width: 15px;
    height: 15px;
  }

  .pub-feature-name {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.84rem;
    font-weight: 600;
    color: #1a2e25;
    margin: 0 0 2px;
  }

  .pub-feature-detail {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.73rem;
    color: rgba(30,50,40,0.5);
    margin: 0;
    line-height: 1.45;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .s-publicidad {
      padding: 44px 4vw;
      min-height: auto;
      align-items: flex-start;
    }
    .pub-inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .pub-features-card {
      max-height: none;
    }
    .pub-deco-mountain { width: 220px; }
    .pub-deco-cable    { width: 160px; }
  }

  @media (max-width: 480px) {
    .pub-price-main { font-size: 3.4rem; }
    .s-publicidad { padding: 44px 5vw; }
  }
</style>

<div class="inicio-root wali-root">

  <!-- ===== HERO ===== -->
  <section class="w-section hero-wali" style="position: relative; display: flex; align-items: center; justify-content: center;">
    <div class="hero-wali-bg" style="background-image: url('/images/lapaz.jpg')"></div>
    <div class="hero-wali-overlay"></div>
    
    <div class="hero-content-split">
      <div class="hero-wali-inner">
        <div class="badge reveal scale-in">
          <span class="bdot"></span>
          Aventuras Paceñas S.R.L.
        </div>
        <h1 class="hero-title reveal from-left reveal-delay-1">
          Conoce a <em>Wali</em>
        </h1>
        <p class="hero-sub reveal from-left reveal-delay-2">
          Tu navaja suiza para explorar La Paz. La aplicación móvil diseñada exclusivamente para turistas, fusionando la sabiduría local con tecnología de punta para que tu experiencia sea inolvidable.
        </p>
        <div class="hero-btns reveal from-left reveal-delay-3">
          <button class="btn-p" onclick="scrollToFeatures()">Descubrir Funciones ↓</button>
          <a href="/descarga" class="btn-s">Descargar App</a>
        </div>
      </div>

      <div class="hero-promo reveal from-right reveal-delay-4">
        <div class="promo-card">
          <div class="promo-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
          </div>
          <h3 class="promo-title">Inicia tu Aventura</h3>
          <p class="promo-desc">Regístrate ahora y crea tu cuenta para acceder a la <strong>App Móvil Wali</strong>. Explora, planifica y descubre la ciudad sin límites.</p>
          <a href="/registro" class="promo-btn">Crear mi Cuenta</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SECCIÓN FEATURES (CARRUSEL HORIZONTAL) ===== -->
  <section class="w-section feat-showcase" id="features-section">
    
    <div class="feat-showcase-header reveal from-bottom">
      <p class="feat-showcase-eyebrow">Todo lo que necesitas</p>
      <h2 class="feat-showcase-title">Las ventajas de <em>Wali</em></h2>
      <p class="feat-showcase-sub">7 funciones pensadas para tu experiencia en La Paz</p>
    </div>

    <div class="feat-tabs reveal from-bottom reveal-delay-1" id="feat-tabs">
      {features.map((f, i) => (
        <button class={`feat-tab ${i === 0 ? 'active' : ''}`} data-index={i} aria-label={f.title}>
          <span class="feat-tab-icon" set:html={f.icon}></span>
          <span class="feat-tab-label">{f.tag}</span>
        </button>
      ))}
    </div>

    <div class="feat-panel-wrapper reveal from-bottom reveal-delay-2">
      {features.map((feat, i) => (
        <div class={`feat-panel ${i === 0 ? 'active' : ''}`} data-panel={i} id={`panel-${feat.id}`}>
          <div class="feat-panel-bg" style={`background-image: url('${feat.bg}')`}></div>
          <div class="feat-panel-overlay"></div>
          <div class="feat-panel-inner">
            <div class="feat-panel-text">
              <div class="feat-panel-tag">{feat.tag}</div>
              <h3 class="feat-panel-title">{feat.title}</h3>
              <p class="feat-panel-desc">{feat.desc}</p>
              <div class="feat-panel-details">
                {feat.detail.split(' · ').map(d => (
                  <span class="feat-detail-chip">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                    {d}
                  </span>
                ))}
              </div>
            </div>
            <div class="feat-panel-mockup">
              <div class="mockup-orb"></div>
              <div class="mockup-line-top"></div>
              <div class="mockup-line-left"></div>
              <div class="mockup-diamond"></div>
              <div class="mockup-cross"></div>
              <div class="mockup-dots-grid">
                {Array.from({ length: 16 }).map(() => (
                  <span></span>
                ))}
              </div>
              <div class="mockup-phone-frame">
                <div class="mockup-notch"></div>
                <div class="mockup-screen">
                  <img src={feat.interfaz} alt={`Interfaz de ${feat.title}`} loading="lazy" />
                </div>
              </div>
              <div class="mockup-badge" style={`background: ${feat.color}`}>
                <span set:html={feat.icon}></span>
              </div>
            </div>
          </div>
          <div class="feat-panel-counter">
            <span class="counter-current">{String(i + 1).padStart(2, '0')}</span>
            <span class="counter-sep">/</span>
            <span class="counter-total">{String(features.length).padStart(2, '0')}</span>
          </div>
        </div>
      ))}
    </div>

    <div class="feat-dots" id="feat-dots">
      {features.map((_, i) => (
        <button class={`feat-dot ${i === 0 ? 'active' : ''}`} data-dot={i} aria-label={`Ir a ${features[i].title}`}>
          <span class="feat-dot-progress"></span>
        </button>
      ))}
    </div>

    <button class="feat-autoplay-btn" id="feat-autoplay-btn" aria-label="Pausar autoplay" title="Pausar autoplay">
      <svg class="icon-pause" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
      <svg class="icon-play" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" style="display:none"><polygon points="5 3 19 12 5 21 5 3"/></svg>
    </button>

    <div class="feat-arrows">
      <button class="feat-arrow feat-arrow-prev" id="feat-prev" aria-label="Anterior">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <button class="feat-arrow feat-arrow-next" id="feat-next" aria-label="Siguiente">
