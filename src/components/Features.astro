---
import './Features.css';

// Las secciones mantienen su data, pero el diseño será unificado al estilo claro.
const features = [
  {
    id: 'audioguia', tag: 'Contexto Histórico', title: 'Audioguías Narrativas',
    desc: 'Wali te enviará una notificación al acercarte a un sitio turístico, activando audioguías inmersivas que te explicarán toda la historia y el contexto del lugar.',
    bg: '/images/calle_jaen.jpg',
    interfaz: '/images/interfaz1.png'
  },
  {
    id: 'mapas', tag: 'Cartografía Avanzada', title: 'Mapas y Geolocalización',
    desc: 'Observa tu entorno con precisión. Encuentra sitios de interés, descubre rutas turísticas recomendadas y visualiza el mapa interactivo offline.',
    bg: '/images/altiplano.jpg',
    interfaz: '/images/interfaz2.png'
  },
  {
    id: 'itinerarios', tag: 'Planificación a Medida', title: 'Itinerarios Inteligentes',
    desc: 'Dinos qué te gusta y nosotros armamos el plan. Escoge tus actividades y Wali generará un itinerario recomendado, completamente editable.',
    bg: '/images/valle_luna.jpg',
    interfaz: '/images/interfaz3.png'
  },
  {
    id: 'asistente', tag: 'Atención 24/7', title: 'Asistente Inteligente',
    desc: 'Tu guía paceño de bolsillo. Nuestro chatbot de IA está listo para hacerte recomendaciones de rutas y resolver dudas turísticas en tiempo real.',
    bg: '/images/mirador_killi.jpg',
    interfaz: '/images/interfaz4.png'
  },
  {
    id: 'gastronomia', tag: 'Sabores sin Riesgos', title: 'Decodificador Gastronómico',
    desc: 'Apunta tu cámara al menú. Wali identificará el plato, mostrará sus ingredientes y preparación para prevenir reacciones alérgicas y sorpresas.',
    bg: '/images/mercado_ancestral.jpg',
    interfaz: '/images/interfaz5.png'
  },
  {
    id: 'seguridad', tag: 'Exploración Segura', title: 'Seguridad y Tranquilidad',
    desc: 'Muévete con confianza. El mapa marca zonas de precaución y cuentas con un botón de pánico integrado para llamar a la policía en emergencias.',
    bg: '/images/twanaku.jpg',
    interfaz: '/images/interfaz6.png'
  },
  {
    id: 'tarifas', tag: 'Economía Justa', title: 'Recomendador de Tarifas',
    desc: 'Evita cobros excesivos. En una ciudad sin taxímetros, nuestra herramienta te calcula la tarifa recomendada para tu ruta de transporte.',
    bg: '/images/Ciudad_de_La_Paz_de_noche.jpg',
    interfaz: '/images/interfaz7.png'
  }
];
---

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;0,700;1,600;1,700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

<div class="inicio-root wali-root">

  <section class="w-section hero-wali" style="position: relative; display: flex; align-items: center; justify-content: center;">
    <div class="hero-wali-bg" style="background-image: url('/images/lapaz.jpg')"></div>
    <div class="hero-wali-overlay"></div>
    
    {/* CONTENEDOR SPLIT: Divide el espacio entre el texto a la izquierda y la promo a la derecha */}
    <div class="hero-content-split" style="position: relative; z-index: 2; display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; width: 100%; max-width: 1200px; padding: 0 2rem; gap: 2rem;">
        
        {/* PARTE IZQUIERDA: Textos originales */}
        <div class="hero-wali-inner" style="flex: 1 1 500px; max-width: 600px; margin: 0;">
          <div class="badge reveal scale-in">
            <span class="bdot"></span>
            Aventuras Paceñas S.R.L.
          </div>
          
          <h1 class="hero-title reveal from-left reveal-delay-1">
            Conoce a <em>Wali</em>
          </h1>
          
          <p class="hero-sub reveal from-left reveal-delay-2">
            Tu navaja suiza para explorar La Paz. La aplicación móvil diseñada exclusivamente para turistas, fusionando la sabiduría local con tecnología de punta para que tu experiencia sea inolvidable.
          </p>
          
          <div class="hero-btns reveal from-left reveal-delay-3">
            <button class="btn-p" onclick="scrollToSection(1)">Descubrir Funciones ↓</button>
            <a href="/descarga" class="btn-s">Descargar App</a>
          </div>
        </div>

        {/* PARTE DERECHA: Nueva tarjeta de promoción de Registro */}
        <div class="hero-promo reveal from-right reveal-delay-4" style="flex: 0 1 400px;">
            <div class="promo-card" style="background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(12px); padding: 2.5rem; border-radius: 20px; box-shadow: 0 24px 48px rgba(0,0,0,0.2); text-align: center; border: 1px solid rgba(255,255,255,0.5);">
                
                <div style="background: var(--color-teal); width: 64px; height: 64px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; color: white; box-shadow: 0 8px 16px rgba(15, 152, 138, 0.3);">
                    <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><line x1="19" y1="8" x2="19" y2="14"></line><line x1="22" y1="11" x2="16" y2="11"></line></svg>
                </div>
                
                <h3 style="color: var(--color-dark); font-family: 'Cormorant Garamond', serif; font-size: 2rem; font-weight: 700; margin-bottom: 1rem; line-height: 1.2;">
                    Inicia tu Aventura
                </h3>
                
                <p style="color: var(--color-dark); font-size: 1.05rem; margin-bottom: 2rem; line-height: 1.5;">
                    Regístrate ahora y crea tu cuenta para acceder a la <strong>App Móvil Wali</strong>. Explora, planifica y descubre la ciudad sin límites.
                </p>
                
                <a href="/registro" style="display: block; width: 100%; padding: 14px 20px; background: var(--color-orange); color: white; font-weight: 600; text-decoration: none; border-radius: 12px; font-size: 1.1rem; box-shadow: 0 8px 20px rgba(210, 120, 23, 0.35); transition: background 0.3s ease;">
                    Crear mi Cuenta
                </a>

            </div>
        </div>

    </div>
  </section>

  {features.map((feat, index) => (
    <section class="w-section feat-section" style="position: relative;">
      
      <div class="feat-bg-img" style={`background-image: url('${feat.bg}')`}></div>
      <div class="feat-bg-overlay overlay-cream"></div>

      <div class="feat-header reveal from-bottom">
        <div class="stag-main">{feat.tag}</div>
        <h2 class="stit-main">{feat.title}</h2>
      </div>

      <div class={`feat-container ${index % 2 !== 0 ? 'row-reverse' : ''}`}>
        
        {/* TEXTO CENTRADO */}
        <div class="feat-text-content" style="display: flex; align-items: center; justify-content: center; height: 100%;">
          <div class="feat-text-card card-white reveal from-left">
            <p class="feat-desc">
              {feat.desc}
            </p>
          </div>
        </div>

        {/* CONTENEDOR VISUAL ESTANDARIZADO PARA LA INTERFAZ */}
        <div class="feat-visual-content reveal scale-in reveal-delay-2" style="display: flex; align-items: center; justify-content: center; height: 100%;">
          
          <div class="mockup-container" style="width: 260px; height: 448px; border-radius: 24px; overflow: hidden; box-shadow: 0 16px 40px rgba(0,0,0,0.25); background: var(--white); position: relative; flex-shrink: 0; margin-bottom: 1.5rem;">
            <img 
              src={feat.interfaz} 
              alt={`Interfaz de ${feat.title}`} 
              loading="lazy" 
              style="width: 100%; height: 100%; object-fit: cover; object-position: top center; display: block;"
            />
          </div>

          
        </div>

      </div>
    </section>
  ))}

  <section class="w-section s-cta">
    <div class="s-cta::before"></div>
    <div class="cta-tag reveal">📱 DISPONIBLE AHORA</div>

    <h2 class="stit-main reveal reveal-delay-1" style="text-align: center; margin-bottom: 15px;">
      ¿Listo para llevar<br />a <em style="color: var(--color-orange); font-style: italic;">La Paz</em> en tu bolsillo?
    </h2>

    <p class="reveal reveal-delay-2" style="text-align: center; margin: 0 auto 32px; color: var(--color-dark); font-size: 1.15rem;">
      Únete a los viajeros que ya están redefiniendo el turismo local con la tecnología desarrollada por Aventuras Paceñas.
    </p>

    <div class="cta-btns reveal reveal-delay-4">
      <a href="/descarga" class="btn-p">
        <img src="/icons/telefono.png" style="width:18px;height:18px;object-fit:contain;vertical-align:middle;margin-right:4px" alt="" />
        Descargar Wali Ahora
      </a>
    </div>
  </section>

</div>

<script>
  // Observer para animaciones
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target); 
        }
      });
    },
    { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

  // Lógica de Navegación por Secciones
  const sections = Array.from(document.querySelectorAll('.w-section'));
  let currentSection = 0;
  let isScrolling = false;

  function getActiveSection() {
    const mid = window.innerHeight / 2;
    let closest = 0;
    let closestDist = Infinity;
    sections.forEach((s, i) => {
      const rect = s.getBoundingClientRect();
      const dist = Math.abs(rect.top + rect.height / 2 - mid);
      if (dist < closestDist) { closestDist = dist; closest = i; }
    });
    return closest;
  }

  window.scrollToSection = function(idx) {
    if (idx < 0 || idx >= sections.length || isScrolling) return;
    isScrolling = true;
    currentSection = idx;
    const el = sections[idx];
    const headerH = document.querySelector('header')?.offsetHeight || 0; 
    const top = el.getBoundingClientRect().top + window.scrollY - headerH;
    window.scrollTo({ top, behavior: 'smooth' });
    setTimeout(() => { isScrolling = false; }, 900);
  }

  // Dots de navegación derecha
  const navDots = document.createElement('div');
  navDots.id = 'section-nav';
  navDots.innerHTML = sections.map((_, i) =>
    `<button class="snav-dot" data-i="${i}" aria-label="Ir a sección ${i + 1}"></button>`
  ).join('');
  document.querySelector('.wali-root').appendChild(navDots);

  // Hint teclado
  const kbHint = document.createElement('div');
  kbHint.id = 'kb-hint';
  kbHint.innerHTML = `<div class="kb-key">▲</div><div class="kb-key">▼</div>`;
  document.querySelector('.wali-root').appendChild(kbHint);

  navDots.querySelectorAll('.snav-dot').forEach(dot => {
    dot.addEventListener('click', () => window.scrollToSection(+dot.dataset.i));
  });

  function updateActiveDot() {
    const active = getActiveSection();
    currentSection = active;
    navDots.querySelectorAll('.snav-dot').forEach((d, i) =>
      d.classList.toggle('active', i === active)
    );
  }

  window.addEventListener('scroll', updateActiveDot, { passive: true });
  updateActiveDot();

  // Atajos Teclado
  document.addEventListener('keydown', e => {
    if (['INPUT','TEXTAREA','SELECT'].includes(document.activeElement?.tagName)) return;
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      window.scrollToSection(getActiveSection() + 1);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      window.scrollToSection(getActiveSection() - 1);
    }
  });
</script>