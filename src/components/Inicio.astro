          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════
       CTA FINAL
  ══════════════════════════════════════ -->
  <section class="s-cta">
    <div class="s-cta::before"></div>

    <div class="cta-tag reveal">📱 Disponible ahora</div>

    <h2 class="reveal reveal-delay-1">¿Listo para descubrir<br /><em>La Paz</em>?</h2>

    <p class="reveal reveal-delay-2">
      Lleva un guía paceño en tu bolsillo. Nuestra app te acompaña en cada rincón de la ciudad —
      desde la Calle de las Brujas hasta el Charquini — con mapas offline, información de sitios
      y rutas personalizadas.
    </p>

    <div class="cta-features reveal reveal-delay-3">
      <div class="cta-feat">
        <span class="cta-feat-ic">🗺</span>
        <span>Mapas offline</span>
      </div>
      <div class="cta-feat">
        <span class="cta-feat-ic">🧭</span>
        <span>Guía de sitios</span>
      </div>
      <div class="cta-feat">
        <span class="cta-feat-ic">⭐</span>
        <span>Rutas personalizadas</span>
      </div>
      <div class="cta-feat">
        <span class="cta-feat-ic">🔒</span>
        <span>Sin conexión</span>
      </div>
    </div>

    <div class="cta-btns reveal reveal-delay-4">
      <a href="/descarga" class="btn-p">
        <img src="/icons/telefono.png" style="width:18px;height:18px;object-fit:contain;vertical-align:middle;margin-right:4px" alt="" />
        Descargar la App
      </a>
    </div>

    <div class="cta-note reveal reveal-delay-5">
      Gratis · Funciona sin internet
    </div>
  </section>



  <div class="mb" id="modal-backdrop">
    <div class="md" id="modal-box">
      <button class="md-close" id="modal-close">✕</button>
      <img class="md-img" id="modal-img" src="" alt="" />
      <div class="md-body">
        <div class="md-cat" id="modal-cat"></div>
        <div class="md-title" id="modal-title"></div>
        <div class="md-desc" id="modal-desc"></div>
        <div class="md-hls" id="modal-hls"></div>
        <div class="md-foot">
          <button class="btn-pm" id="btn-reservar">Reservar este tour</button>
          <button class="btn-sm" id="modal-cerrar">Cerrar</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Toast de confirmación -->
  <div id="toast" class="toast-box">
    <span class="toast-icon">✅</span>
    <div>
      <strong class="toast-title">¡Solicitud recibida!</strong>
      <span class="toast-sub">Nos pondremos en contacto contigo pronto.</span>
    </div>
  </div>

</div><!-- /inicio-root -->


<script>

function loadLeaflet() {
  return new Promise((resolve) => {
    if (window.L) { resolve(); return; }
    const link = document.createElement('link');
    link.rel = 'stylesheet';
    link.href = 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css';
    document.head.appendChild(link);
    const script = document.createElement('script');
    script.src = 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js';
    script.onload = resolve;
    document.head.appendChild(script);
  });
}

document.addEventListener('DOMContentLoaded', async () => {
  await loadLeaflet();
  initMap();
});

function initMap() {
  const mapEl = document.getElementById('map');
  if (!mapEl || mapEl._leaflet_id) return;

  const map = L.map('map', {
    center: [-16.5000, -68.1193],
    zoom: 13,
    zoomControl: true,
    scrollWheelZoom: false,
  });

  L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
    attribution: '© CartoDB',
    maxZoom: 19,
  }).addTo(map);

  const spots = [
    { lat: -16.4955, lng: -68.1336, name: 'Calle de las Brujas',   desc: 'Misticismo aymara' },
    { lat: -16.5400, lng: -68.0800, name: 'Valle de la Luna',      desc: 'Naturaleza única' },
    { lat: -16.4900, lng: -68.1200, name: 'Mirador Killi Killi',   desc: 'La Paz a tus pies' },
    { lat: -16.4970, lng: -68.1330, name: 'Iglesia San Francisco', desc: 'Joya colonial' },
    { lat: -16.4960, lng: -68.1344, name: 'Plaza Murillo',         desc: 'Corazón político' },
    { lat: -16.4940, lng: -68.1350, name: 'Calle Jaén',            desc: 'La más colonial' },
    { lat: -16.5010, lng: -68.1300, name: 'Teleférico',            desc: 'Vuela sobre La Paz' },
  ];

  const pulseIcon = L.divIcon({
    className: '',
    html: `<div style="
      width:12px;height:12px;border-radius:50%;
      background:#D27817;
      box-shadow:0 0 0 5px rgba(210,120,23,.24),0 0 0 10px rgba(210,120,23,.09);
      animation:pm 2s ease-in-out infinite
    "></div>`,
    iconSize: [12, 12],
    iconAnchor: [6, 6],
  });

  spots.forEach(s => {
    L.marker([s.lat, s.lng], { icon: pulseIcon })
      .addTo(map)
      .bindPopup(
        `<b style="font-family:'Cormorant Garamond',serif">${s.name}</b>
         <br><span style="font-size:.76rem;color:#999">${s.desc}</span>`,
        { className: 'dp' }
      );
  });

  document.querySelectorAll('.mp-item').forEach((el, i) => {
    el.addEventListener('click', () =>
      map.setView([spots[i].lat, spots[i].lng], 15, { animate: true })
    );
  });
}

