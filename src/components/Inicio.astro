---
import './Inicio.css';
---

<!-- Google Fonts -->
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;0,700;1,600;1,700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

<div class="inicio-root">


  <section class="hero">

    <!-- Slides de fondo (fotos de La Paz) -->
    <div class="hero-slides">
      <div
        class="hero-slide active"
        style="background-image: url('/images/Ciudad_de_La_Paz_de_noche.jpg')"
        data-label="La Paz de noche"
      ></div>
      <div
        class="hero-slide"
        style="background-image: url('/images/cordillera.jpg')"
        data-label="Cordillera de los Andes"
      ></div>
      <div
        class="hero-slide"
        style="background-image: url('/images/mercado_ancestral.jpg')"
        data-label="Mercado Ancestral"
      ></div>
      <div
        class="hero-slide"
        style="background-image: url('/images/altiplano.jpg')"
        data-label="Altiplano Boliviano"
      ></div>
    </div>

    <div class="hero-overlay"></div>

    <!-- Etiqueta del slide activo -->
    <div class="slide-label show" id="hero-label">
      <div class="slide-label-bar"></div>
      <div class="slide-label-text" id="hero-label-text">La Paz de noche</div>
    </div>

    <!-- Flechas -->
    <button class="hero-arr p" id="hero-prev" aria-label="Anterior">&#8592;</button>
    <button class="hero-arr n" id="hero-next" aria-label="Siguiente">&#8594;</button>

    <!-- Dots indicadores -->
    <div class="hero-dots" id="hero-dots"></div>

    <!-- Contenido principal -->
    <div class="hero-inner">
      <div>
        <div class="badge">
          <span class="bdot"></span>
          Operadora de Turismo Receptivo · La Paz, Bolivia
        </div>

        <h1 class="hero-title">
          <em>Aventuras Paceñas</em>
          S.R.L.
        </h1>

        <p class="hero-sub">
          Somos una operadora de turismo receptivo con sede en La Paz, dedicada a conectar al viajero con el patrimonio cultural y geográfico andino. Organizamos experiencias de viaje integrales: guiado especializado, traslados estratégicos y asesoría personalizada para que descubras La Paz como nunca antes.
        </p>

        <div class="hero-btns">
          <a href="/nosotros" class="btn-p">Conoce quiénes somos →</a>
          <a href="#paquetes" class="btn-s">Ver nuestros paquetes</a>
        </div>

        <div class="hero-stats">
          <div class="hst">
            <div class="hst-n">120+</div>
            <div class="hst-l">Sitios en La Paz</div>
          </div>
          <div class="hst">
            <div class="hst-n">4.9★</div>
            <div class="hst-l">Valoración media</div>
          </div>
          <div class="hst">
            <div class="hst-n">5,000+</div>
            <div class="hst-l">Turistas atendidos</div>
          </div>
        </div>
      </div>

      <!-- Tarjeta flotante — qué ofrecemos -->
      <div class="fcard">
        <div class="fcard-top">
          <div class="fcard-pin"><img src="/icons/ubicacion.png" style="width:14px;height:14px;object-fit:contain" alt="" /></div>
          <div>
            <div class="fcard-loc">Aventuras Paceñas S.R.L.</div>
            <div class="fcard-alt">La Paz, Bolivia · Turismo Receptivo</div>
          </div>
        </div>
        <div class="fcard-list">
          <div class="fcard-item"><span class="fdot"></span>Guiado especializado andino</div>
          <div class="fcard-item"><span class="fdot"></span>Traslados y logística integral</div>
          <div class="fcard-item"><span class="fdot"></span>Patrimonio cultural y natural</div>
          <div class="fcard-item"><span class="fdot"></span>Asesoría personalizada</div>
          <div class="fcard-item"><span class="fdot"></span>App de acompañamiento</div>
        </div>
        <div class="fcard-stats">
          <div class="fcard-stat"><span class="fcard-stat-n">3,640</span><span class="fcard-stat-l">msnm · La ciudad más alta</span></div>
          <div class="fcard-stat"><span class="fcard-stat-n">9+</span><span class="fcard-stat-l">destinos disponibles</span></div>
          <div class="fcard-stat"><span class="fcard-stat-n">365</span><span class="fcard-stat-l">días operando</span></div>
        </div>
      </div>
    </div>

    <div class="scroll-ind">
      <span>Explorar</span>
      <div class="scroll-bar"></div>
    </div>

    <!-- Ticker dentro del hero, pegado al fondo -->
    <div class="ticker">
      <div class="ticker-track">
        <span class="ticker-item">Calle de las Brujas<span class="tsep"></span></span>
        <span class="ticker-item">Valle de la Luna<span class="tsep"></span></span>
        <span class="ticker-item">Mirador Killi Killi<span class="tsep"></span></span>
        <span class="ticker-item">Plaza Murillo<span class="tsep"></span></span>
        <span class="ticker-item">Tiwanaku<span class="tsep"></span></span>
        <span class="ticker-item">Lago Titicaca<span class="tsep"></span></span>
        <span class="ticker-item">Nevado Charquini<span class="tsep"></span></span>
        <span class="ticker-item">Chacaltaya<span class="tsep"></span></span>
        <span class="ticker-item">Calle Jaén<span class="tsep"></span></span>
        <span class="ticker-item">Iglesia San Francisco<span class="tsep"></span></span>
        <span class="ticker-item">Mercado de las Brujas<span class="tsep"></span></span>
        <span class="ticker-item">Teleférico Mi Teleférico<span class="tsep"></span></span>
        <span class="ticker-item">Calle de las Brujas<span class="tsep"></span></span>
        <span class="ticker-item">Valle de la Luna<span class="tsep"></span></span>
        <span class="ticker-item">Mirador Killi Killi<span class="tsep"></span></span>
        <span class="ticker-item">Plaza Murillo<span class="tsep"></span></span>
        <span class="ticker-item">Tiwanaku<span class="tsep"></span></span>
        <span class="ticker-item">Lago Titicaca<span class="tsep"></span></span>
        <span class="ticker-item">Nevado Charquini<span class="tsep"></span></span>
        <span class="ticker-item">Chacaltaya<span class="tsep"></span></span>
        <span class="ticker-item">Calle Jaén<span class="tsep"></span></span>
        <span class="ticker-item">Iglesia San Francisco<span class="tsep"></span></span>
        <span class="ticker-item">Mercado de las Brujas<span class="tsep"></span></span>
        <span class="ticker-item">Teleférico Mi Teleférico<span class="tsep"></span></span>
      </div>
    </div>

  </section>

  <section class="s-galeria">
    <div class="g-header reveal">
      <div class="stag">La Paz en imágenes</div>
      <h2 class="stit">Cada rincón cuenta una historia</h2>
    </div>

    <div class="ph-wrap">
      <button class="ph-btn p" id="ph-prev" aria-label="Anterior">&#8592;</button>
      <div class="ph-outer">
        <div class="ph-track" id="ph-track">

          <div class="ph-card reveal scale-in reveal-delay-1">
            <img src="/images/Ciudad_de_La_Paz_de_noche.jpg" alt="La Paz de noche" loading="lazy" />
            <div class="ph-ov"></div>
            <div class="ph-info">
              <div class="ph-name">La Paz de noche</div>
              <div class="ph-sub">La hoyada paceña iluminada</div>
            </div>
          </div>

          <div class="ph-card reveal scale-in reveal-delay-2">
            <img src="/images/cordillera.jpg" alt="Cordillera de los Andes" loading="lazy" />
            <div class="ph-ov"></div>
            <div class="ph-info">
              <div class="ph-name">Cordillera de los Andes</div>
              <div class="ph-sub">El telón de fondo eterno de La Paz</div>
            </div>
          </div>

          <div class="ph-card reveal scale-in reveal-delay-3">
            <img src="/images/valle_luna.jpg" alt="Valle de la Luna" loading="lazy" />
            <div class="ph-ov"></div>
            <div class="ph-info">
              <div class="ph-name">Valle de la Luna</div>
              <div class="ph-sub">Formaciones rocosas únicas</div>
            </div>
          </div>

          <div class="ph-card reveal scale-in reveal-delay-4">
            <img src="/images/mercado_ancestral.jpg" alt="Mercado Ancestral" loading="lazy" />
            <div class="ph-ov"></div>
            <div class="ph-info">
              <div class="ph-name">Mercado Ancestral</div>
              <div class="ph-sub">Colores y tradiciones aymaras</div>
            </div>
          </div>

          <div class="ph-card reveal scale-in reveal-delay-5">
            <img src="/images/centro_historico.jpg" alt="Centro Histórico" loading="lazy" />
            <div class="ph-ov"></div>
            <div class="ph-info">
              <div class="ph-name">Centro Histórico</div>
              <div class="ph-sub">Arquitectura colonial boliviana</div>
            </div>
          </div>

          <div class="ph-card reveal scale-in reveal-delay-6">
            <img src="/images/altiplano.jpg" alt="Altiplano Boliviano" loading="lazy" />
            <div class="ph-ov"></div>
            <div class="ph-info">
              <div class="ph-name">Altiplano Boliviano</div>
              <div class="ph-sub">Paisajes que quitan el aliento</div>
            </div>
          </div>

        </div>
      </div>
      <button class="ph-btn n" id="ph-next" aria-label="Siguiente">&#8594;</button>
    </div>

    <div class="ph-dots" id="ph-dots"></div>
  </section>

  <section class="s-paq" id="paquetes">
    <div class="s-hdr reveal">
      <div class="stag-dk">Nuestros Paquetes</div>
      <h2 class="stit stit-dk">Recorre La Paz con nosotros</h2>
    </div>

    <div class="paq-slider-wrap">
      <button class="paq-btn p" id="paq-prev" aria-label="Anterior">&#8592;</button>
      <div class="paq-slider-outer">
        <div class="pgrid" id="paq-track">

          <div class="pc" data-modal="brujas">
            <div class="pc-thumb"><img src="/images/calle_de_las_brujas.jpg" alt="Calle de las Brujas" loading="lazy" /><div class="pc-thumb-ov"></div><span class="pc-cat">Cultura y Misticismo</span></div>
            <div class="pc-body"><div class="pc-name">Calle de las Brujas y Centro Histórico</div><p class="pc-desc">Sumérgete en la cosmovisión aymara en la famosa Calle Linares, rodeado de amuletos, hierbas y yatiris.</p><button class="pc-cta">Ver más →</button></div>
          </div>

          <div class="pc" data-modal="luna">
            <div class="pc-thumb"><img src="/images/valle_luna.jpg" alt="Valle de la Luna" loading="lazy" /><div class="pc-thumb-ov"></div><span class="pc-cat">Naturaleza Urbana</span></div>
            <div class="pc-body"><div class="pc-name">Valle de la Luna</div><p class="pc-desc">Formaciones de arcilla y arenisca que crean un paisaje de otro mundo a solo 10 km del centro paceño.</p><button class="pc-cta">Ver más →</button></div>
          </div>

          <div class="pc" data-modal="killi">
            <div class="pc-thumb"><img src="/images/mirador_killi.jpg" alt="Mirador Killi Killi" loading="lazy" /><div class="pc-thumb-ov"></div><span class="pc-cat">Panorámico</span></div>
            <div class="pc-body"><div class="pc-name">Mirador Killi Killi y Teleférico</div><p class="pc-desc">La hoyada paceña entera desde el mirador histórico, combinado con el teleférico más alto del mundo.</p><button class="pc-cta">Ver más →</button></div>
          </div>

          <div class="pc" data-modal="jaen">
            <div class="pc-thumb"><img src="/images/calle_jaen.jpg" alt="Calle Jaén" loading="lazy" /><div class="pc-thumb-ov"></div><span class="pc-cat">Historia Colonial</span></div>
            <div class="pc-body"><div class="pc-name">Calle Jaén y Museos Coloniales</div><p class="pc-desc">La calle colonial mejor conservada de Bolivia con sus cuatro museos y casas de la independencia.</p><button class="pc-cta">Ver más →</button></div>
          </div>

          <div class="pc" data-modal="tiwanaku">
            <div class="pc-thumb"><img src="/images/twanaku.jpg" alt="Tiwanaku" loading="lazy" /><div class="pc-thumb-ov"></div><span class="pc-cat">Arqueología</span></div>
            <div class="pc-body"><div class="pc-name">Tiwanaku Arqueológico</div><p class="pc-desc">Patrimonio de la Humanidad UNESCO. La civilización preincaica más importante de los Andes bolivianos.</p><button class="pc-cta">Ver más →</button></div>
          </div>

          <div class="pc" data-modal="titicaca">
            <div class="pc-thumb"><img src="/images/Lago_Titicaca.jpg" alt="Lago Titicaca" loading="lazy" /><div class="pc-thumb-ov"></div><span class="pc-cat">Lago y Naturaleza</span></div>
            <div class="pc-body"><div class="pc-name">Lago Titicaca e Isla del Sol</div><p class="pc-desc">El lago navegable más alto del mundo a 3,800 msnm. Tour de 2 días hasta la mítica Isla del Sol.</p><button class="pc-cta">Ver más →</button></div>
          </div>

          <div class="pc" data-modal="chacaltaya">
            <div class="pc-thumb"><img src="/images/Chacaltaya.jpg" alt="Chacaltaya" loading="lazy" /><div class="pc-thumb-ov"></div><span class="pc-cat">Alta Montaña</span></div>
            <div class="pc-body"><div class="pc-name">Chacaltaya</div><p class="pc-desc">A 5,400 msnm, la antigua pista de esquí más alta del mundo con vistas de La Paz y la Cordillera Real.</p><button class="pc-cta">Ver más →</button></div>
          </div>

          <div class="pc" data-modal="charquini">
            <div class="pc-thumb"><img src="/images/charquini.jpg" alt="Nevado Charquini" loading="lazy" /><div class="pc-thumb-ov"></div><span class="pc-cat">Aventura y Trekking</span></div>
            <div class="pc-body"><div class="pc-name">Nevado Charquini y Laguna Esmeralda</div><p class="pc-desc">A 39 km de La Paz en la Cordillera Real. La Laguna Esmeralda de aguas turquesas junto al glaciar.</p><button class="pc-cta">Ver más →</button></div>
          </div>

          <div class="pc" data-modal="citytour">
            <div class="pc-thumb"><img src="/images/city_tour.jpg" alt="La Paz City Tour" loading="lazy" /><div class="pc-thumb-ov"></div><span class="pc-cat">Tour Urbano</span></div>
            <div class="pc-body"><div class="pc-name">La Paz City Tour</div><p class="pc-desc">Los puntos más emblemáticos de La Paz en un solo día con guía especializado paceño.</p><button class="pc-cta">Ver más →</button></div>
          </div>

        </div>
      </div>
      <button class="paq-btn n" id="paq-next" aria-label="Siguiente">&#8594;</button>
    </div>
    <div class="paq-dots" id="paq-dots"></div>
  </section>



  <section class="s-why">
    <div class="why-in">
      <div>
        <div class="stag reveal from-left" style="color: var(--color-orange)">Por qué elegirnos</div>
        <h2 class="stit reveal from-left reveal-delay-1">Tu experiencia en La Paz<br />es nuestra misión</h2>
        <p class="why-sub">
          Somos paceños. Conocemos cada callejón, cada historia y cada secreto de esta ciudad.
          Combinamos ese conocimiento local con tecnología para que tu visita sea inolvidable.
        </p>
        <div class="feats">
          <div class="feat reveal from-left reveal-delay-2">
            <div class="fi fi1"><img src="/icons/guias.png" class="feat-ic-img" alt="" /></div>
            <div class="feat-t">
              <h4>Guías Locales Paceños</h4>
              <p>Nacimos y crecimos en La Paz, conocemos cada rincón, historia y secreto de la ciudad.</p>
            </div>
          </div>
          <div class="feat reveal from-left reveal-delay-3">
            <div class="fi fi2"><img src="/icons/telefono.png" class="feat-ic-img" alt="" /></div>
            <div class="feat-t">
              <h4>App de Acompañamiento</h4>
              <p>Nuestra app te guía por La Paz incluso después del tour con mapas offline y datos de cada sitio.</p>
            </div>
          </div>
          <div class="feat reveal from-left reveal-delay-4">
            <div class="fi fi3"><img src="/icons/seguro.png" class="feat-ic-img" alt="" /></div>
            <div class="feat-t">
              <h4>Traslados Seguros</h4>
              <p>Vehículos verificados y conductores certificados para moverte con total tranquilidad.</p>
            </div>
          </div>
          <div class="feat reveal from-left reveal-delay-5">
            <div class="fi fi4"><img src="/icons/atencion.png" class="feat-ic-img" alt="" /></div>
            <div class="feat-t">
              <h4>Atención Personalizada</h4>
              <p>Coordinamos tu recorrido desde antes de que llegues, adaptado a tus intereses.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="why-r">
        <div class="wc reveal from-right reveal-delay-1">
          <div class="wc-n">3,640</div>
          <div class="wc-l">msnm · La ciudad más alta del mundo con tanto que descubrir</div>
        </div>
        <div class="wc reveal from-right reveal-delay-2">
          <div class="wc-n am">365</div>
          <div class="wc-l">días · Operamos todo el año en La Paz</div>
        </div>
        <div class="wc reveal from-right reveal-delay-3">
          <div class="wc-n">5,000+</div>
          <div class="wc-l">turistas de más de 40 países han recorrido La Paz con nosotros</div>
        </div>
      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════
       MAPA INTERACTIVO
  ══════════════════════════════════════ -->
