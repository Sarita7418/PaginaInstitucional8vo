function closeMd() {
  document.getElementById('modal-backdrop').classList.remove('open');
  document.body.style.overflow = '';
}

function openMd(key) {
  const d = MD[key];
  if (!d) return;
  document.getElementById('modal-img').src   = d.img;
  document.getElementById('modal-img').alt   = d.title;
  document.getElementById('modal-cat').textContent   = d.cat;
  document.getElementById('modal-title').textContent = d.title;
  document.getElementById('modal-desc').textContent  = d.desc;
  document.getElementById('modal-hls').innerHTML = d.hls
    .map(h => `
      <div class="md-hl">
        <img src="/icons/${h.ic}.png" class="md-hl-ic-img" alt="${h.t}" />
        <div class="md-hl-t">
          <strong>${h.t}</strong>
          <span>${h.d}</span>
        </div>
      </div>`)
    .join('');
  document.getElementById('modal-backdrop').classList.add('open');
  document.body.style.overflow = 'hidden';
}

document.getElementById('modal-close').addEventListener('click', closeMd);
document.getElementById('modal-cerrar').addEventListener('click', closeMd);
document.getElementById('modal-backdrop').addEventListener('click', e => {
  if (e.target === document.getElementById('modal-backdrop')) closeMd();
});
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeMd(); });
document.querySelectorAll('.pc').forEach(c =>
  c.addEventListener('click', () => openMd(c.dataset.modal))
);

/* Botón Reservar → toast */
document.getElementById('btn-reservar').addEventListener('click', () => {
  closeMd();
  const toast = document.getElementById('toast');
  toast.classList.add('show');
  setTimeout(() => toast.classList.remove('show'), 4000);
});

const heroSlides  = document.querySelectorAll('.hero-slide');
const heroDots    = document.getElementById('hero-dots');
const heroLabelEl = document.getElementById('hero-label');
const heroLabelTx = document.getElementById('hero-label-text');
let heroIdx = 0;
let heroTimer;

heroSlides.forEach((s, i) => {
  const d = document.createElement('button');
  d.className = 'hero-dot' + (i === 0 ? ' active' : '');
  d.addEventListener('click', () => goHero(i));
  heroDots.appendChild(d);
});

function goHero(n) {
  heroSlides[heroIdx].classList.remove('active');
  heroDots.children[heroIdx].classList.remove('active');
  heroIdx = (n + heroSlides.length) % heroSlides.length;
  heroSlides[heroIdx].classList.add('active');
  heroDots.children[heroIdx].classList.add('active');
  heroLabelEl.classList.remove('show');
  setTimeout(() => {
    heroLabelTx.textContent = heroSlides[heroIdx].dataset.label;
    heroLabelEl.classList.add('show');
  }, 280);
  clearInterval(heroTimer);
  heroTimer = setInterval(() => goHero(heroIdx + 1), 5500);
}

document.getElementById('hero-prev').addEventListener('click', () => goHero(heroIdx - 1));
document.getElementById('hero-next').addEventListener('click', () => goHero(heroIdx + 1));
heroTimer = setInterval(() => goHero(heroIdx + 1), 5500);

const phTrack = document.getElementById('ph-track');
const phDots  = document.getElementById('ph-dots');
const phCards = phTrack.querySelectorAll('.ph-card');
let phIdx = 0;
let phTimer;

const phVisible = () => window.innerWidth < 580 ? 1 : window.innerWidth < 960 ? 2 : 3;
const phTotal   = () => Math.ceil(phCards.length / phVisible());

function buildPhDots() {
  phDots.innerHTML = '';
  for (let i = 0; i < phTotal(); i++) {
    const d = document.createElement('button');
    d.className = 'pdot' + (i === 0 ? ' active' : '');
    d.addEventListener('click', () => goPhoto(i));
    phDots.appendChild(d);
  }
}
buildPhDots();
window.addEventListener('resize', buildPhDots);

function goPhoto(n) {
  phIdx = (n + phTotal()) % phTotal();
  const w = phCards[0].offsetWidth + 14;
  phTrack.style.transform = `translateX(-${phIdx * phVisible() * w}px)`;
  document.querySelectorAll('.pdot').forEach((d, i) =>
    d.classList.toggle('active', i === phIdx)
  );
  clearInterval(phTimer);
  phTimer = setInterval(() => goPhoto(phIdx + 1), 4200);
}

document.getElementById('ph-prev').addEventListener('click', () => goPhoto(phIdx - 1));
document.getElementById('ph-next').addEventListener('click', () => goPhoto(phIdx + 1));
phTimer = setInterval(() => goPhoto(phIdx + 1), 4200);

const paqTrack  = document.getElementById('paq-track');
const paqDots   = document.getElementById('paq-dots');
const paqCards  = paqTrack ? paqTrack.querySelectorAll('.pc') : [];
let paqIdx = 0;
let paqTimer;

const paqVisible = () => {
  if (window.innerWidth < 580) return 1;
  if (window.innerWidth < 960) return 2;
  return 3;
};
const paqTotal = () => Math.max(1, paqCards.length - paqVisible() + 1);

function buildPaqDots() {
  if (!paqDots) return;
  paqDots.innerHTML = '';
  for (let i = 0; i < paqTotal(); i++) {
    const d = document.createElement('button');
    d.className = 'paq-dot' + (i === 0 ? ' active' : '');
    d.addEventListener('click', () => goPaq(i));
    paqDots.appendChild(d);
  }
}
buildPaqDots();
window.addEventListener('resize', () => { buildPaqDots(); goPaq(0); });

function goPaq(n) {
  paqIdx = (n + paqTotal()) % paqTotal();
  const cardW = paqCards[0] ? paqCards[0].offsetWidth + 20 : 320;
  paqTrack.style.transform = `translateX(-${paqIdx * cardW}px)`;
  document.querySelectorAll('.paq-dot').forEach((d, i) =>
    d.classList.toggle('active', i === paqIdx)
  );
  clearInterval(paqTimer);
  paqTimer = setInterval(() => goPaq(paqIdx + 1), 3800);
}

if (document.getElementById('paq-prev')) {
  document.getElementById('paq-prev').addEventListener('click', () => goPaq(paqIdx - 1));
  document.getElementById('paq-next').addEventListener('click', () => goPaq(paqIdx + 1));
}
paqTimer = setInterval(() => goPaq(paqIdx + 1), 3800);


const observer = new IntersectionObserver(
  (entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target); // solo anima una vez
      }
    });
  },
  { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
);

document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

const sections = [
  document.querySelector('.hero'),
  document.querySelector('.s-galeria'),
  document.querySelector('.s-paq'),
  document.querySelector('.s-why'),
  document.querySelector('.s-mapa'),
  document.querySelector('.s-cta'),
].filter(Boolean);

let currentSection = 0;
let isScrolling = false;

// Detectar qué sección está visible actualmente
function getActiveSection() {
  const mid = window.innerHeight / 2;
  let closest = 0;
  let closestDist = Infinity;
  sections.forEach((s, i) => {
    const rect = s.getBoundingClientRect();
    const dist = Math.abs(rect.top + rect.height / 2 - mid);
    if (dist < closestDist) { closestDist = dist; closest = i; }
  });
  return closest;
}

function scrollToSection(idx) {
  if (idx < 0 || idx >= sections.length || isScrolling) return;
  isScrolling = true;
  currentSection = idx;
  const el = sections[idx];
  const headerH = document.querySelector('.header')?.offsetHeight || 0;
  const top = el.getBoundingClientRect().top + window.scrollY - headerH;
  window.scrollTo({ top, behavior: 'smooth' });
  setTimeout(() => { isScrolling = false; }, 900);
}

// Indicador visual de sección activa
const navDots = document.createElement('div');
navDots.id = 'section-nav';
navDots.innerHTML = sections.map((_, i) =>
  `<button class="snav-dot" data-i="${i}" aria-label="Ir a sección ${i + 1}"></button>`
).join('');
document.querySelector('.inicio-root').appendChild(navDots);

const snavStyle = document.createElement('style');
snavStyle.textContent = `
  #section-nav {
    position: fixed;
    right: 20px;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: 8px;
    z-index: 500;
  }
  .snav-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255,255,255,0.25);
    border: 1px solid rgba(255,255,255,0.35);
    cursor: pointer;
    transition: background 0.3s, transform 0.3s, height 0.3s;
    padding: 0;
  }
  .snav-dot.active {
    background: #D27817;
    border-color: #D27817;
    transform: scale(1.4);
    height: 20px;
    border-radius: 4px;
  }
  .snav-dot:hover { background: rgba(210,120,23,0.6); }

  /* Hint de teclado */
  #kb-hint {
    position: fixed;
    bottom: 90px;
    right: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3px;
    z-index: 500;
    opacity: 0.35;
    transition: opacity 0.3s;
  }
  #kb-hint:hover { opacity: 0.8; }
  .kb-key {
    width: 22px;
    height: 22px;
    border: 1px solid rgba(255,255,255,0.4);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    color: rgba(255,255,255,0.7);
    background: rgba(255,255,255,0.06);
  }
  @media(max-width:680px) {
    #section-nav, #kb-hint { display: none; }
  }
`;
document.head.appendChild(snavStyle);

// Hint de teclado
const kbHint = document.createElement('div');
kbHint.id = 'kb-hint';
kbHint.innerHTML = `<div class="kb-key">▲</div><div class="kb-key">▼</div>`;
document.querySelector('.inicio-root').appendChild(kbHint);

// Click en dots
navDots.querySelectorAll('.snav-dot').forEach(dot => {
  dot.addEventListener('click', () => scrollToSection(+dot.dataset.i));
});

function updateActiveDot() {
  const active = getActiveSection();
  currentSection = active;
  navDots.querySelectorAll('.snav-dot').forEach((d, i) =>
    d.classList.toggle('active', i === active)
  );
}

// Actualizar dot activo en scroll
window.addEventListener('scroll', updateActiveDot, { passive: true });
updateActiveDot();

// Teclado
document.addEventListener('keydown', e => {
  // No interferir si el modal está abierto
  if (document.getElementById('modal-backdrop').classList.contains('open')) return;
  // No interferir si hay un input enfocado
  if (['INPUT','TEXTAREA','SELECT'].includes(document.activeElement?.tagName)) return;

  if (e.key === 'ArrowDown') {
    e.preventDefault();
    scrollToSection(getActiveSection() + 1);
  } else if (e.key === 'ArrowUp') {
    e.preventDefault();
    scrollToSection(getActiveSection() - 1);
  }
});

</script>