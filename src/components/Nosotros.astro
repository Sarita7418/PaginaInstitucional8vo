          <div class="nos-mvv-card slider-item reveal scale-in reveal-delay-1">
            <div class="nos-mvv-num">01</div>
            <div class="nos-mvv-card-head">
              <div class="nos-mvi nos-mvi-teal"><img src="/icons/guias.png" alt="Misión"/></div>
              <span class="nos-mvv-chip nos-mc-teal">Misión</span>
            </div>
            <h3 class="nos-mvv-title">Conectar al mundo con La Paz</h3>
            <p class="nos-mvv-desc">
