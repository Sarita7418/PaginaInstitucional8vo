      <div class="nos-swipe-hint">Desliza para ver más →</div>

    </div>
  </section>

  <section class="n-section nos-equipo">
    <div class="nos-equipo-in">

      <div class="nos-equipo-hdr">
        <div class="nos-chip reveal">Nuestro Equipo</div>
        <h2 class="nos-section-title nos-title-lt reveal reveal-delay-1">
          La mente técnica<br /><em>de tu expedición</em>
        </h2>
        <p class="nos-equipo-lead reveal reveal-delay-2">
          Ingenieros de sistemas y creativos digitales. Un equipo local que une la pasión por La Paz con la innovación tecnológica.
        </p>
      </div>

      <div class="nos-slider-wrapper">
        <div class="nos-team-grid">

          <div class="nos-tcard slider-item reveal scale-in reveal-delay-1">
            <div class="nos-tcard-top nos-tc1">
              <div class="nos-tcard-aro"><div class="nos-tcard-av nos-av1"></div></div>
              <div class="nos-tcard-badge">Fundador</div>
            </div>
            <div class="nos-tcard-body">
              <div class="nos-tcard-name">Jhovanni Gutierrez</div>
              <div class="nos-tcard-rol">Ingeniero · Scrum Master</div>
