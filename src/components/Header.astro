---
/* src/components/Header.astro */
import './Header.css';
---

<header class="header" id="main-header">
  <a href="/" class="header-logo">
    <img src="/images/logo.png" alt="Logo Aventuras Paceñas" class="logo-img" />
  </a>

  <div class="nav-line-filler"></div>

  <ul class="header-nav">
    <li><a href="/" class="nav-link">Inicio</a></li>
    <li><a href="/features" class="nav-link">Características</a></li>
    <li><a href="/nosotros" class="nav-link">Nosotros</a></li>
    <li><a href="/faqs" class="nav-link">FAQ</a></li>
  </ul>

  <div class="nav-line-filler"></div>

  <div class="header-actions">
    <a href="/login" class="nav-link btn-login-nav">Login</a>
    <a href="/descarga" class="btn-descarga">Descargar App</a>
  </div>
</header>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const header = document.getElementById("main-header");
    
    window.addEventListener("scroll", () => {
      if (window.scrollY > 50) {
        header?.classList.add("scrolled");
      } else {
        header?.classList.remove("scrolled");
      }
    });
  });
</script>