---
import "./Header.css";
---

<header class="header" id="main-header">
  <a href="/" class="header-logo">
    <img src="/images/logo.png" alt="Logo Aventuras Paceñas" class="logo-img" />
  </a>

  <button class="mobile-menu-toggle" aria-label="Abrir menú" id="menu-toggle">
    <span class="bar"></span>
    <span class="bar"></span>
    <span class="bar"></span>
  </button>

  <div class="nav-container" id="nav-menu">
    <div class="mobile-menu-header">
      <img src="/images/logo.png" alt="Logo" class="menu-top-logo" />
      <span class="menu-top-name">Aventuras Paceñas</span>
      <div class="menu-header-line"></div>
    </div>

    <div class="mobile-menu-content">
      <ul class="header-nav">
        <li><a href="/" class="nav-link">Inicio</a></li>
        <li class="nav-divider"></li>
        <li>
          <a href="/features" class="nav-link">Aplicación Móvil "WALI"</a>
        </li>
        <li class="nav-divider"></li>
        <li><a href="/nosotros" class="nav-link">Nosotros</a></li>
        <li class="nav-divider"></li>
        <li><a href="/faqs" class="nav-link">Preguntas Frecuentes</a></li>
      </ul>

      <div class="header-actions">
        <div id="auth-guest" class="auth-group">
          <a href="/login" class="btn-nav btn-login">Iniciar Sesión</a>
          <div class="separator-line"></div>
          <a href="/registro" class="btn-nav btn-register">Registrarse</a>
        </div>

        <div
          id="auth-user"
          class="auth-user-info"
          style="display: none !important;"
        >
          <div class="user-profile-btn" id="user-menu-trigger">
            <div class="user-avatar-small">
              <span id="user-initial">U</span>
            </div>
            <div class="user-details-mini">
              <span id="user-name-display" class="user-name-text"
                >Cargando...</span
              >
              <span id="user-email-display" class="user-email-text"
                >correo@ejemplo.com</span
              >
            </div>
            <svg
              class="chevron-icon"
              width="12"
              height="12"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="3"><path d="M6 9l6 6 6-6"></path></svg
            >
          </div>

          <div id="user-dropdown" class="user-dropdown">
            <div class="dropdown-header">
              <span id="user-role-tag">Turista</span>
            </div>

            <a
              href="/dashboard"
              id="admin-link"
              class="dropdown-link"
              style="display: none;"
            >
              Panel de Control
            </a>

            <button id="btn-logout" class="dropdown-link logout"
              >Cerrar Sesión</button
            >
          </div>
        </div>
      </div>
    </div>

    <div class="mobile-menu-footer">
      <p class="menu-copyright">
        &copy; {new Date().getFullYear()} Derechos Reservados
      </p>
    </div>
  </div>
</header>
<script>
  import { supabase } from "../lib/supabase";
// --- LÓGICA DE LA HAMBURGUESA (VERSIÓN ULTRA-COMPATIBLE) ---
  const initMobileMenu = () => {
    // Usamos delegación de eventos en el document
    // Esto funciona aunque el botón se cargue después o cambies de página
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      // Buscamos si el clic fue en el botón o dentro de sus barras
      const toggle = target.closest('#menu-toggle');
      const navMenu = document.getElementById('nav-menu');

      if (toggle && navMenu) {
        e.preventDefault();
        toggle.classList.toggle('active');
        navMenu.classList.toggle('active');
        document.body.classList.toggle('no-scroll');
      }
      
      // EXTRA: Cerrar el menú si haces clic en un enlace (nav-link)
      if (target.classList.contains('nav-link')) {
        const menu = document.getElementById('nav-menu');
        const btn = document.getElementById('menu-toggle');
        menu?.classList.remove('active');
        btn?.classList.remove('active');
        document.body.classList.remove('no-scroll');
      }
    });
  };

  // Ejecución inmediata
  initMobileMenu();

  // Reiniciar solo si usas ViewTransitions
  document.addEventListener("astro:page-load", () => {
    // No hace falta re-ejecutar si usamos addEventListener al document, 
    // pero lo dejamos por si acaso el CSS necesita resetearse
    const menu = document.getElementById('nav-menu');
    const btn = document.getElementById('menu-toggle');
    menu?.classList.remove('active');
    btn?.classList.remove('active');
  });
  const initAuth = async () => {
    // Selectores de elementos
    const authGuest = document.getElementById("auth-guest");
    const authUser = document.getElementById("auth-user");
    const userNameDisplay = document.getElementById("user-name-display");
    const userEmailDisplay = document.getElementById("user-email-display");
    const userInitial = document.getElementById("user-initial");
    const userRoleTag = document.getElementById("user-role-tag");
    
    // CORRECCIÓN: Casteo a HTMLAnchorElement para evitar error de 'href'
    const adminLink = document.getElementById("admin-link") as HTMLAnchorElement | null;

    const updateUI = async (session) => {
      if (session?.user) {
        // 1. Mostrar contenedor de usuario, ocultar invitado
        authGuest?.setAttribute("style", "display: none !important");
        authUser?.setAttribute("style", "display: flex !important");

        if (userEmailDisplay) userEmailDisplay.textContent = session.user.email;

        // 2. Buscar en tabla personas por el UUID de la sesión
        const { data: persona, error: dbError } = await supabase
          .from("personas")
          .select("nombres, id_rol")
          .eq("id_usuario", session.user.id)
          .maybeSingle();

        if (dbError) console.error("Error al obtener perfil:", dbError.message);

        if (persona) {
          // Mostrar nombre real de la tabla
          if (userNameDisplay) userNameDisplay.textContent = persona.nombres;
          if (userInitial) userInitial.textContent = persona.nombres.charAt(0).toUpperCase();

          // 3. Lógica de ROLES (2 = Administrador, 1 = Turismo)
          const rol = Number(persona.id_rol);
          
          if (rol === 2) {
            if (userRoleTag) {
              userRoleTag.textContent = "Administrador";
              userRoleTag.style.color = "#D27817";
            }
            if (adminLink) {
              adminLink.style.setProperty("display", "block", "important");
              adminLink.href = "/dashboard";
              console.log("Acceso ADMIN detectado para:", persona.nombres);
            }
          } else {
            if (userRoleTag) {
              userRoleTag.textContent = "Turismo";
              userRoleTag.style.color = "#28a745";
            }
            if (adminLink) adminLink.style.setProperty("display", "none", "important");
          }
        } else {
          // Fallback si el usuario no existe en la tabla 'personas'
          const fallbackName = session.user.email.split("@")[0];
          if (userNameDisplay) userNameDisplay.textContent = fallbackName;
          if (userInitial) userInitial.textContent = fallbackName.charAt(0).toUpperCase();
          if (userRoleTag) userRoleTag.textContent = "Invitado";
        }
      } else {
        // ESTADO INVITADO (Sin sesión)
        authGuest?.setAttribute("style", "display: flex !important");
        authUser?.setAttribute("style", "display: none !important");
      }
    };

    // Escuchar cambios de autenticación en tiempo real
    supabase.auth.onAuthStateChange((_event, session) => {
      updateUI(session);
    });

    // Revisión inicial de sesión
    const { data: { session } } = await supabase.auth.getSession();
    updateUI(session);

    // Evento Logout
    document.getElementById("btn-logout")?.addEventListener("click", async (e) => {
      e.preventDefault();
      await supabase.auth.signOut();
      window.location.href = "/";
    });

    // Evento Dropdown
    const trigger = document.getElementById("user-menu-trigger");
    const dropdown = document.getElementById("user-dropdown");

    trigger?.addEventListener("click", (e) => {
      e.stopPropagation();
      dropdown?.classList.toggle("active");
    });

    document.addEventListener("click", () => dropdown?.classList.remove("active"));
  };

  // Inicialización compatible con Astro ViewTransitions
  initAuth();
  document.addEventListener("astro:page-load", initAuth);
</script>