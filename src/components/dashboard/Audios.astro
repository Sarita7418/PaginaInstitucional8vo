  // ════════════════════════════════════════════════
  // IA SIMULACIÓN
  // ════════════════════════════════════════════════
  document.getElementById('btn-generar-ia')?.addEventListener('click', () => {
    const titulo = document.getElementById('au-titulo').value;
    const punto  = document.getElementById('au-punto');
    const puntoNombre = punto.options[punto.selectedIndex]?.text || 'este sitio';
    if (!titulo) { showToast('Completa el título primero', 'error'); return; }
    const texto = `Bienvenidos a ${puntoNombre}. ${titulo}. Este fascinante lugar en La Paz, Bolivia, es un testimonio vivo de la cultura andina. A lo largo de su historia, ha sido testigo de importantes eventos que forjaron la identidad de la ciudad. Te invitamos a explorar cada rincón y descubrir los secretos que guarda.`;
    document.getElementById('au-texto').value = texto;
    document.getElementById('ag-preview-box').style.display  = 'block';
    document.getElementById('ag-preview-text').textContent   = texto;
    showToast('Texto generado con IA — revísalo antes de guardar');
  });

  // ════════════════════════════════════════════════
  // PREVIEW EN TIEMPO REAL
  // ════════════════════════════════════════════════
  document.getElementById('au-texto')?.addEventListener('input', e => {
    const val = e.target.value.trim();
    const box  = document.getElementById('ag-preview-box');
    const prev = document.getElementById('ag-preview-text');
    if (val.length > 10) { box.style.display = 'block'; prev.textContent = val; }
    else { box.style.display = 'none'; }
  });

  document.getElementById('au-duracion')?.addEventListener('input', e => {
    const seg   = parseInt(e.target.value);
    const badge = document.getElementById('ag-duracion-preview');
    const txt   = document.getElementById('ag-duracion-text');
    if (seg > 0) { badge.style.display = 'flex'; txt.textContent = formatDuracion(seg); }
    else { badge.style.display = 'none'; }
  });

  // ════════════════════════════════════════════════
  // FILTROS TABLA
  // ════════════════════════════════════════════════
  document.getElementById('search-audios')?.addEventListener('input',    e => { filtrosBusq   = e.target.value; paginaAudios = 1; loadAudios(); });
  document.getElementById('filter-idioma-audios')?.addEventListener('change', e => { filtrosIdioma = e.target.value; paginaAudios = 1; loadAudios(); });
  document.getElementById('filter-estado-audios')?.addEventListener('change', e => { filtrosEstado = e.target.value; paginaAudios = 1; loadAudios(); });

  // ════════════════════════════════════════════════
  // TOGGLE RADIOS
  // ════════════════════════════════════════════════
  document.querySelectorAll('.ag-toggle-group').forEach(group => {
    group.querySelectorAll('input[type=radio]').forEach(radio => {
      radio.addEventListener('change', () => {
        group.querySelectorAll('.ag-toggle-opt').forEach(opt => opt.classList.remove('ag-toggle-active'));
        radio.parentElement.classList.add('ag-toggle-active');
      });
    });
  });

  // ════════════════════════════════════════════════
  // NAVEGACIÓN ENTRE PANELES
  // ════════════════════════════════════════════════
  const initAudiosModule = () => {
    const cards  = document.querySelectorAll('.ag-action-card');
    const panels = document.querySelectorAll('.ag-panel');

    cards.forEach(card => {
      card.addEventListener('click', () => {
        const panelId = 'ag-panel-' + card.getAttribute('data-panel');
        cards.forEach(c => c.classList.remove('ag-card-active'));
        card.classList.add('ag-card-active');
        panels.forEach(p => p.classList.remove('active'));
        document.getElementById(panelId)?.classList.add('active');
        if (panelId === 'ag-panel-editar')           loadAudios();
        if (panelId === 'ag-panel-idiomas')          loadIdiomasPanel();
        if (panelId === 'ag-panel-gestionar-estado') loadEstadoAudios();
      });
    });

    document.getElementById('btn-nueva-audio')?.addEventListener('click', () => {
      document.querySelector('[data-panel="subir"]')?.click();
    });
    document.getElementById('btn-cancelar-audio')?.addEventListener('click', () => {
      document.querySelector('[data-panel="editar"]')?.click();
    });

    loadIdiomas().then(() => { loadPuntos(); loadStats(); });
  };

  initAudiosModule();
  document.addEventListener('astro:page-load', initAudiosModule);
</script>