---
// Componente Sitios Turísticos
---

<section data-section-target="sitios" class="section card">
  <div class="card-header">
    <h2 class="card-title">Sitios Turísticos</h2>
    <p class="card-subtitle">Administra los sitios turísticos y su información disponible</p>
  </div>

  <div class="table-container">
    <table>
      <thead>
        <tr>
          <th>Sitio Turístico</th>
          <th>Ubicación</th>
          <th>Categoría</th>
          <th>Visitantes</th>
          <th>Calificación</th>
          <th>Estado</th>
          <th>Acción</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Catedral Metropolitana</td>
          <td>Plaza Murillo, La Paz</td>
          <td>Religioso</td>
          <td>3,456</td>
          <td>4.8/5</td>
          <td><span style="background-color: #6b6b6b; color: white; padding: 4px 8px; border-radius: 4px; font-size: 12px;">Abierto</span></td>
          <td><button class="button button-primary button-small">MODIFICAR ESTADO</button></td>
        </tr>
        <tr>
          <td>Museo Nacional</td>
          <td>Zona Monumental</td>
          <td>Museo</td>
          <td>2,134</td>
          <td>4.6/5</td>
          <td><span style="background-color: #6b6b6b; color: white; padding: 4px 8px; border-radius: 4px; font-size: 12px;">Abierto</span></td>
          <td><button class="button button-primary button-small">MODIFICAR ESTADO</button></td>
        </tr>
        <tr>
          <td>Convento de San Francisco</td>
          <td>Calle Comercio, La Paz</td>
          <td>Religioso</td>
          <td>1,789</td>
          <td>4.7/5</td>
          <td><span style="background-color: #6b6b6b; color: white; padding: 4px 8px; border-radius: 4px; font-size: 12px;">Abierto</span></td>
          <td><button class="button button-primary button-small">MODIFICAR ESTADO</button></td>
        </tr>
        <tr>
          <td>Mercado de las Brujas</td>
          <td>Calle Linares, La Paz</td>
          <td>Comercial</td>
          <td>4,567</td>
          <td>4.4/5</td>
          <td><span style="background-color: #6b6b6b; color: white; padding: 4px 8px; border-radius: 4px; font-size: 12px;">Abierto</span></td>
          <td><button class="button button-primary button-small">MODIFICAR ESTADO</button></td>
        </tr>
        <tr>
          <td>Valle de la Luna</td>
          <td>Formaciones de Serranía, Sopocachi</td>
          <td>Natural</td>
          <td>2,234</td>
          <td>4.9/5</td>
          <td><span style="background-color: #6b6b6b; color: white; padding: 4px 8px; border-radius: 4px; font-size: 12px;">Abierto</span></td>
          <td><button class="button button-primary button-small">MODIFICAR ESTADO</button></td>
        </tr>
        <tr>
          <td>Teleférico La Paz</td>
          <td>Estación Central</td>
          <td>Transporte/Atracción</td>
          <td>5,678</td>
          <td>4.5/5</td>
          <td><span style="background-color: #8a8a8a; color: white; padding: 4px 8px; border-radius: 4px; font-size: 12px;">Mantenimiento</span></td>
          <td><button class="button button-primary button-small">MODIFICAR ESTADO</button></td>
        </tr>
        <tr>
          <td>Plaza San Francisco</td>
          <td>Centro de La Paz</td>
          <td>Público</td>
          <td>3,890</td>
          <td>4.3/5</td>
          <td><span style="background-color: #6b6b6b; color: white; padding: 4px 8px; border-radius: 4px; font-size: 12px;">Abierto</span></td>
          <td><button class="button button-primary button-small">MODIFICAR ESTADO</button></td>
        </tr>
        <tr>
          <td>Iglesia de Santo Domingo</td>
          <td>Zona Sudoeste, La Paz</td>
          <td>Religioso</td>
          <td>1,456</td>
          <td>4.7/5</td>
          <td><span style="background-color: #6b6b6b; color: white; padding: 4px 8px; border-radius: 4px; font-size: 12px;">Abierto</span></td>
          <td><button class="button button-primary button-small">MODIFICAR ESTADO</button></td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- Modal para Modificar Estado -->
  <div id="statusModal" class="modal">
    <div class="modal-content">
      <div class="modal-header">
        <h3 class="modal-title">Modificar Estado del Sitio</h3>
        <button class="modal-close" onclick="closeModal('statusModal')">✕</button>
      </div>
      <div class="modal-body">
        <div class="form-group">
          <label class="form-label">Sitio Turístico</label>
          <input type="text" class="form-control" value="Catedral Metropolitana" disabled />
        </div>
        <div class="form-group">
          <label class="form-label">Estado Actual</label>
          <select class="form-control">
            <option selected>Abierto</option>
            <option>Cerrado</option>
            <option>Mantenimiento</option>
            <option>Reservado</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Disponible para Audioguías</label>
          <select class="form-control">
            <option selected>Sí</option>
            <option>No</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Notas</label>
          <textarea class="form-control" rows="3" placeholder="Notas o cambios importantes..."></textarea>
        </div>
      </div>
      <div class="modal-footer">
        <button class="button button-secondary" onclick="closeModal('statusModal')">Cancelar</button>
        <button class="button button-primary">Guardar Cambios</button>
      </div>
    </div>
  </div>

  <script>
    // Agregar event listeners a los botones de modificar estado
    document.addEventListener('DOMContentLoaded', () => {
      const buttons = document.querySelectorAll('[data-section-target="sitios"] .button-primary');
      buttons.forEach(button => {
        button.addEventListener('click', () => {
          openModal('statusModal');
        });
      });
    });
  </script>
</section>
