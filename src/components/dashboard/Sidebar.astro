    <div class="sidebar-brand-logo">T</div>
    <div class="sidebar-brand-text">TourHub</div>
  </div>

  <!-- Navegación Principal -->
  <nav class="sidebar-nav">
    <li class="sidebar-nav-item">
      <a href="#inicio" class="sidebar-nav-link" data-section="inicio">
        <span class="sidebar-nav-icon">•</span>
        <span>Inicio</span>
      </a>
    </li>
    <li class="sidebar-nav-item">
      <a href="#usuarios" class="sidebar-nav-link" data-section="usuarios">
        <span class="sidebar-nav-icon">•</span>
        <span>Usuarios</span>
      </a>
    </li>
    <li class="sidebar-nav-item">
      <a href="#audios" class="sidebar-nav-link" data-section="audios">
        <span class="sidebar-nav-icon">•</span>
        <span>Audios</span>
      </a>
    </li>
    <li class="sidebar-nav-item">
      <a href="#rutas" class="sidebar-nav-link" data-section="rutas">
        <span class="sidebar-nav-icon">•</span>
        <span>Rutas</span>
      </a>
    </li>
    <li class="sidebar-nav-item">
      <a href="#mapas" class="sidebar-nav-link" data-section="mapas">
        <span class="sidebar-nav-icon">•</span>
        <span>Mapas</span>
      </a>
    </li>
    <li class="sidebar-nav-item">
      <a href="#rag" class="sidebar-nav-link" data-section="rag">
        <span class="sidebar-nav-icon">•</span>
        <span>Contexto RAG</span>
      </a>
    </li>
  </nav>

  <!-- Perfil del Usuario -->
  <div class="sidebar-profile">
    <div class="sidebar-profile-item">
      <div class="profile-avatar">
        <img src="https://i.pravatar.cc/150?img=12" alt="User Avatar" />
      </div>
      <div class="profile-info">
        <div class="profile-name">Juan González</div>
        <div class="profile-email">admin@tourhub.com</div>
      </div>
    </div>
  </div>
</aside>
