<script>
  import { supabase } from "../../lib/supabase";

  const initSidebar = async () => {
    // 1. SELECTORES (Usamos una función interna para asegurar que existan)
    const getElements = () => ({
      nameDisplay: document.getElementById("sidebar-user-name"),
      emailDisplay: document.getElementById("sidebar-user-email"),
      avatarPlaceholder: document.getElementById("avatar-placeholder"),
      brandLogo: document.getElementById("sidebar-initial"),
    });

    const updateSidebarUI = async (session: any) => {
      const el = getElements();

      if (!session?.user) {
        console.log("Sidebar: Sin sesión activa.");
        return;
      }

      // Mostrar email del Auth inmediatamente
      if (el.emailDisplay) el.emailDisplay.textContent = session.user.email;

      try {
        // Consultar a la tabla personas
        const { data: persona, error } = await supabase
          .from("personas")
          .select("nombres")
          .eq("id_usuario", session.user.id)
          .maybeSingle();

        if (error) throw error;

        if (persona && persona.nombres) {
          console.log("Sidebar: Nombre cargado ->", persona.nombres);

          if (el.nameDisplay) el.nameDisplay.textContent = persona.nombres;

          const initial = persona.nombres.charAt(0).toUpperCase();
          if (el.avatarPlaceholder) el.avatarPlaceholder.textContent = initial;
          if (el.brandLogo) el.brandLogo.textContent = initial;
        } else {
          // Fallback: Si no hay datos en 'personas', usar el correo
          console.warn("Sidebar: Usuario no encontrado en tabla personas.");
          const fallback = session.user.email.split("@")[0];
          if (el.nameDisplay) el.nameDisplay.textContent = fallback;
        }
      } catch (err) {
        console.error("Error cargando datos del Sidebar:", err);
      }
    };

    // --- EJECUCIÓN ---
    // Escuchar cambios de sesión
    supabase.auth.onAuthStateChange((_event, session) => {
      updateSidebarUI(session);
    });

    // Carga inicial forzada con un pequeño retraso para asegurar el DOM
    setTimeout(async () => {
      const {
        data: { session },
      } = await supabase.auth.getSession();
      await updateSidebarUI(session);
    }, 100);
  };

  // Inicializar en carga y en transiciones de página
  initSidebar();
  document.addEventListener("astro:page-load", initAuth); // IMPORTANTE: usa el nombre de tu función
</script>

