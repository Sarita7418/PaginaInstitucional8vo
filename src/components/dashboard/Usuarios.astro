    min-height: 320px;
  }

  .us-panel { display: none; padding: 28px; animation: usFadeIn 0.22s ease; }
  .us-panel.active { display: block; }
  @keyframes usFadeIn { from { opacity:0; transform:translateY(6px); } to { opacity:1; transform:translateY(0); } }

  /* ── Modal propio ── */
  .us-modal {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(35,55,62,0.55);
    z-index: 3000;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(2px);
  }
  .us-modal-content {
    background: white;
    border-radius: 12px;
    max-width: 750px;
    width: 92%;
    box-shadow: 0 20px 60px rgba(35,55,62,0.25);
    overflow: hidden;
  }
  .us-modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: #f8f9fa;
    padding: 20px 24px;
