    transition: color 0.2s;
  }
  .us-modal-close:hover { color: #1C2B30; }
  .us-modal-body {
    max-height: 65vh;
    overflow-y: auto;
    padding: 25px;
  }
  .us-modal-footer {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
    padding: 20px 25px;
    border-top: 1px solid #eee;
    background: #f8f9fa;
  }

  /* ── Secciones de form ── */
  .stylish-form .form-section-box {
    background: #fdfdfd;
    border: 1px solid #e9ecef;
    border-radius: 8px;
    padding: 15px 20px;
    margin-bottom: 20px;
  }
  .stylish-form .section-title {
    color: #0F988A;
    font-size: 1em;
    font-weight: 600;
    margin-top: 0;
    margin-bottom: 15px;
    padding-bottom: 8px;
    border-bottom: 2px solid #edf2f7;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  /* ── Grids ── */
  .ag-form-grid-2 { display: grid; grid-template-columns: repeat(2,1fr); gap: 15px; margin-bottom: 15px; }
  .ag-form-grid-3 { display: grid; grid-template-columns: repeat(3,1fr); gap: 15px; margin-bottom: 15px; }

  /* ── Password ── */
  .password-wrapper { position: relative; display: flex; align-items: center; }
  .btn-toggle-pass {
    position: absolute; right: 12px;
    background: none; border: none; padding: 0;
    cursor: pointer; color: #6c757d;
    display: flex; align-items: center; justify-content: center;
  }
  .btn-toggle-pass:hover { color: #0F988A; }

  /* ── Checkbox ── */
  .checkbox-container { display: flex; align-items: center; gap: 10px; height: 100%; padding-top: 22px; }
  .custom-checkbox { width: 20px; height: 20px; cursor: pointer; accent-color: #0F988A; margin: 0; }
  .checkbox-container label { margin-bottom: 0; cursor: pointer; font-weight: 500; }

  /* ── Responsive ── */
  @media (max-width: 1100px) { .us-actions-grid { grid-template-columns: repeat(2,1fr); } }
  @media (max-width: 768px) {
    .ag-form-grid-2, .ag-form-grid-3 { grid-template-columns: 1fr; }
    .us-actions-grid { grid-template-columns: repeat(2,1fr); }
    .us-panel { padding: 18px; }
  }
</style>