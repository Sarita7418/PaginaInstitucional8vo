  </div>
</section>

<!-- Modal Cargar Usuario -->
<div id="usuariosModal" class="modal">
  <div class="modal-content">
    <div class="modal-header">
      <h3 class="modal-title">➕ CARGAR Nuevo Usuario</h3>
      <button class="modal-close" onclick="closeModal('usuariosModal')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label class="form-label">Nombres</label>
        <input type="text" class="form-control" placeholder="Ej: Juan Michael" />
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Apellido Paterno</label>
          <input type="text" class="form-control" placeholder="Ej: Gutiérrez" />
        </div>
        <div class="form-group">
          <label class="form-label">Apellido Materno</label>
          <input type="text" class="form-control" placeholder="Ej: Jiménez" />
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Teléfono</label>
          <input type="tel" class="form-control" placeholder="Ej: 76599447" />
        </div>
        <div class="form-group">
          <label class="form-label">Fecha Nacimiento</label>
          <input type="date" class="form-control" />
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Email</label>
        <input type="email" class="form-control" placeholder="Ej: usuario@email.com" />
      </div>
      <div class="form-group">
        <label class="form-label">Rol</label>
        <select class="form-control">
          <option>Usuario Regular</option>
          <option>Guía Turístico</option>
          <option>Administrador</option>
        </select>
      </div>
    </div>
    <div class="modal-footer">
      <button class="button button-secondary" onclick="closeModal('usuariosModal')">Cancelar</button>
      <button class="button button-primary">Guardar Usuario</button>
    </div>
  </div>
</div>

<!-- Modal Actualizar Usuario -->
<div id="editarUsuariosModal" class="modal">
  <div class="modal-content">
    <div class="modal-header">
      <h3 class="modal-title">✎ ACTUALIZAR Usuario</h3>
      <button class="modal-close" onclick="closeModal('editarUsuariosModal')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label class="form-label">Nombres</label>
        <input type="text" class="form-control" value="Jhovanni Michael" />
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Apellido Paterno</label>
          <input type="text" class="form-control" value="Gutierrez" />
        </div>
        <div class="form-group">
          <label class="form-label">Apellido Materno</label>
          <input type="text" class="form-control" value="Jimenez" />
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Teléfono</label>
          <input type="tel" class="form-control" value="76599447" />
        </div>
        <div class="form-group">
          <label class="form-label">Fecha Nacimiento</label>
          <input type="date" class="form-control" value="2004-07-06" />
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Email</label>
        <input type="email" class="form-control" value="jhovanni@email.com" />
      </div>
      <div class="form-group">
        <label class="form-label">Rol</label>
        <select class="form-control">
          <option>Usuario Regular</option>
          <option>Guía Turístico</option>
          <option selected>Administrador</option>
        </select>
      </div>
    </div>
    <div class="modal-footer">
      <button class="button button-secondary" onclick="closeModal('editarUsuariosModal')">Cancelar</button>
      <button class="button button-primary">Actualizar Usuario</button>
    </div>
  </div>
</div>
