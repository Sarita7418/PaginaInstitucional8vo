---
// Componente Rutas - CRUD
---

<section data-section-target="rutas" class="section card">
  <div class="card-header">
    <div style="display: flex; justify-content: space-between; align-items: center;">
      <div>
        <h2 class="card-title"> Gestión de Rutas</h2>
        <p class="card-subtitle">Administra las rutas turísticas disponibles</p>
      </div>
      <button class="button button-primary" onclick="openModal('rutasModal')">
        ➕ CARGAR
      </button>
    </div>
  </div>

  <div class="table-container">
    <table>
      <thead>
        <tr>
          <th>ID</th>
          <th>Nombre Ruta</th>
          <th>Categoría</th>
          <th>Tiempo Estimado</th>
          <th>Distancia Total (km)</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>#R001</td>
          <td>Ruta Colonial</td>
          <td><span style="background-color: #a0a0a0; color: white; padding: 4px 8px; border-radius: 4px; font-size: 12px;">Histórica</span></td>
          <td>2.5 hrs</td>
          <td>3.2</td>
          <td>
            <button class="button button-secondary button-small" onclick="openModal('editarRutasModal')">ACTUALIZAR</button>
            <button class="button button-danger button-small">DAR DE BAJA</button>
          </td>
        </tr>
        <tr>
          <td>#R002</td>
          <td>Circuito Museos</td>
          <td><span style="background-color: #8a8a8a; color: white; padding: 4px 8px; border-radius: 4px; font-size: 12px;">Gastronómica</span></td>
          <td>3.5 hrs</td>
          <td>5.8</td>
          <td>
            <button class="button button-secondary button-small" onclick="openModal('editarRutasModal')">ACTUALIZAR</button>
            <button class="button button-danger button-small">DAR DE BAJA</button>
          </td>
        </tr>
        <tr>
          <td>#R003</td>
          <td>Arquitectura Paceña</td>
          <td><span style="background-color: #6b6b6b; color: white; padding: 4px 8px; border-radius: 4px; font-size: 12px;">Arquitectónica</span></td>
          <td>4.0 hrs</td>
          <td>6.5</td>
          <td>
            <button class="button button-secondary button-small" onclick="openModal('editarRutasModal')">ACTUALIZAR</button>
            <button class="button button-danger button-small">DAR DE BAJA</button>
          </td>
        </tr>
        <tr>
          <td>#R004</td>
          <td>Sabores Bolivianos</td>
          <td><span style="background-color: #9a9a9a; color: white; padding: 4px 8px; border-radius: 4px; font-size: 12px;">Gastronómica</span></td>
          <td>3.0 hrs</td>
          <td>2.1</td>
          <td>
            <button class="button button-secondary button-small" onclick="openModal('editarRutasModal')">ACTUALIZAR</button>
            <button class="button button-danger button-small">DAR DE BAJA</button>
          </td>
        </tr>
      </tbody>
    </table>
  </div>
</section>

<!-- Modal Cargar Ruta -->
<div id="rutasModal" class="modal">
  <div class="modal-content">
    <div class="modal-header">
      <h3 class="modal-title">➕ CARGAR Nueva Ruta</h3>
      <button class="modal-close" onclick="closeModal('rutasModal')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label class="form-label">Nombre de la Ruta</label>
        <input type="text" class="form-control" placeholder="Ej: Ruta Colonial" />
      </div>
      <div class="form-group">
        <label class="form-label">Descripción de la Ruta</label>
        <textarea class="form-control" rows="3" placeholder="Resumen de lo que el turista experimentará en este trayecto..."></textarea>
      </div>
      <div class="form-group">
        <label class="form-label">Categoría de Preferencia</label>
        <select class="form-control">
          <option>Histórica</option>
          <option>Gastronómica</option>
          <option>Arquitectónica</option>
          <option>Natural</option>
          <option>Cultural</option>
          <option>Religiosa</option>
        </select>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Tiempo Estimado (hrs)</label>
          <input type="number" class="form-control" placeholder="Ej: 2.5" step="0.5" />
        </div>
        <div class="form-group">
          <label class="form-label">Distancia Total (km)</label>
          <input type="number" class="form-control" placeholder="Ej: 3.2" step="0.1" />
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="button button-secondary" onclick="closeModal('rutasModal')">Cancelar</button>
      <button class="button button-primary">Guardar Ruta</button>
    </div>
  </div>
</div>

<!-- Modal Actualizar Ruta -->
<div id="editarRutasModal" class="modal">
  <div class="modal-content">
    <div class="modal-header">
      <h3 class="modal-title">✎ ACTUALIZAR Ruta</h3>
      <button class="modal-close" onclick="closeModal('editarRutasModal')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label class="form-label">Nombre de la Ruta</label>
        <input type="text" class="form-control" value="Ruta Colonial" />
      </div>
      <div class="form-group">
        <label class="form-label">Descripción de la Ruta</label>
        <textarea class="form-control" rows="3">Experimente la historia colonial de La Paz visitando arquitectura única...</textarea>
      </div>
      <div class="form-group">
        <label class="form-label">Categoría de Preferencia</label>
        <select class="form-control">
          <option selected>Histórica</option>
          <option>Gastronómica</option>
          <option>Arquitectónica</option>
          <option>Natural</option>
          <option>Cultural</option>
          <option>Religiosa</option>
        </select>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Tiempo Estimado (hrs)</label>
          <input type="number" class="form-control" value="2.5" step="0.5" />
        </div>
        <div class="form-group">
          <label class="form-label">Distancia Total (km)</label>
          <input type="number" class="form-control" value="3.2" step="0.1" />
        </div>
      </div>
      <button class="button button-secondary" onclick="closeModal('editarRutasModal')">Cancelar</button>
      <button class="button button-primary">Actualizar Ruta</button>
    </div>
  </div>
</div>
