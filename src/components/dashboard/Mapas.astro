---
// Componente Mapas - CRUD
---

<section data-section-target="mapas" class="section card">
  <div class="card-header">
    <div style="display: flex; justify-content: space-between; align-items: center;">
      <div>
        <h2 class="card-title">Gestión de Mapas</h2>
        <p class="card-subtitle">Administra los mapas offline y zonas geográficas</p>
      </div>
      <button class="button button-primary" onclick="openModal('mapasModal')">
        ➕ CARGAR
      </button>
    </div>
  </div>

  <div class="table-container">
    <table>
      <thead>
        <tr>
          <th>ID</th>
          <th>Nombre Zona</th>
          <th>Tipo Zona</th>
          <th>Peso Mapa (MB)</th>
          <th>Con Alerta</th>
          <th>Acciones</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>#M001</td>
          <td>Centro Histórico Paceño</td>
          <td><span style="background-color: #a0a0a0; color: white; padding: 4px 8px; border-radius: 4px; font-size: 12px;">Turística Normal</span></td>
          <td>45.3</td>
          <td>No</td>
          <td>
            <button class="button button-secondary button-small" onclick="openModal('editarMapasModal')">ACTUALIZAR</button>
            <button class="button button-danger button-small">DAR DE BAJA</button>
          </td>
        </tr>
        <tr>
          <td>#M002</td>
          <td>Sopocachi</td>
          <td><span style="background-color: #8a8a8a; color: white; padding: 4px 8px; border-radius: 4px; font-size: 12px;">Zona Precaución</span></td>
          <td>32.8</td>
          <td>Sí</td>
          <td>
            <button class="button button-secondary button-small" onclick="openModal('editarMapasModal')">ACTUALIZAR</button>
            <button class="button button-danger button-small">DAR DE BAJA</button>
          </td>
        </tr>
        <tr>
          <td>#M003</td>
          <td>Zona Monumental</td>
          <td><span style="background-color: #a0a0a0; color: white; padding: 4px 8px; border-radius: 4px; font-size: 12px;">Turística Normal</span></td>
          <td>28.5</td>
          <td>No</td>
          <td>
            <button class="button button-secondary button-small" onclick="openModal('editarMapasModal')">ACTUALIZAR</button>
            <button class="button button-danger button-small">DAR DE BAJA</button>
          </td>
        </tr>
        <tr>
          <td>#M004</td>
          <td>Zona Periférica</td>
          <td><span style="background-color: #6b6b6b; color: white; padding: 4px 8px; border-radius: 4px; font-size: 12px;">Zona de Riesgo</span></td>
          <td>56.2</td>
          <td>Sí</td>
          <td>
            <button class="button button-secondary button-small" onclick="openModal('editarMapasModal')">ACTUALIZAR</button>
            <button class="button button-danger button-small">DAR DE BAJA</button>
          </td>
        </tr>
      </tbody>
    </table>
  </div>
</section>

<!-- Modal Cargar Mapa -->
<div id="mapasModal" class="modal">
  <div class="modal-content">
    <div class="modal-header">
      <h3 class="modal-title">➕ CARGAR Nuevo Mapa</h3>
      <button class="modal-close" onclick="closeModal('mapasModal')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label class="form-label">Nombre Zona</label>
        <input type="text" class="form-control" placeholder="Ej: Centro Histórico Paceño" />
      </div>
      <div class="form-group">
        <label class="form-label">Tipo de Zona</label>
        <select class="form-control">
          <option>Turística Normal</option>
          <option>Zona de Precaución</option>
          <option>Zona de Riesgo</option>
        </select>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Peso Mapa (MB)</label>
          <input type="number" class="form-control" placeholder="Ej: 45.3" step="0.1" />
        </div>
        <div class="form-group">
          <label class="form-label">Url Paquete Offline</label>
          <input type="text" class="form-control" placeholder="Ej: /maps/centro-historico.mbtiles" />
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Polígono Área (Coordenadas)</label>
        <textarea class="form-control" rows="2" placeholder="Ej: [-16.5,−68.1], [-16.5,−68.13], ..."></textarea>
      </div>
      <div class="form-group">
        <label class="form-label">Mensaje de Alerta (si aplica)</label>
        <textarea class="form-control" rows="2" placeholder="Mensaje preventivo para zonas de riesgo o precaución..."></textarea>
      </div>
    </div>
    <div class="modal-footer">
      <button class="button button-secondary" onclick="closeModal('mapasModal')">Cancelar</button>
      <button class="button button-primary">Guardar Mapa</button>
    </div>
  </div>
</div>

<!-- Modal Actualizar Mapa -->
<div id="editarMapasModal" class="modal">
  <div class="modal-content">
    <div class="modal-header">
      <h3 class="modal-title">✎ ACTUALIZAR Mapa</h3>
      <button class="modal-close" onclick="closeModal('editarMapasModal')">✕</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label class="form-label">Nombre Zona</label>
        <input type="text" class="form-control" value="Centro Histórico Paceño" />
      </div>
      <div class="form-group">
        <label class="form-label">Tipo de Zona</label>
        <select class="form-control">
          <option selected>Turística Normal</option>
          <option>Zona de Precaución</option>
          <option>Zona de Riesgo</option>
        </select>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Peso Mapa (MB)</label>
          <input type="number" class="form-control" value="45.3" step="0.1" />
        </div>
        <div class="form-group">
          <label class="form-label">Url Paquete Offline</label>
          <input type="text" class="form-control" value="/maps/centro-historico.mbtiles" />
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Polígono Área (Coordenadas)</label>
        <textarea class="form-control" rows="2">[-16.5,−68.1], [-16.5,−68.13], [-16.52,−68.13], [-16.52,−68.1]</textarea>
      </div>
      <div class="form-group">
        <label class="form-label">Mensaje de Alerta (si aplica)</label>
        <textarea class="form-control" rows="2" placeholder="Deja vacío si no hay alerta..."></textarea>
      </div>
    </div>
    <div class="modal-footer">
      <button class="button button-secondary" onclick="closeModal('editarMapasModal')">Cancelar</button>
      <button class="button button-primary">Actualizar Mapa</button>
    </div>
  </div>
</div>
