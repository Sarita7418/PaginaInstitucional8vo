---
import MainLayout from "../layouts/MainLayout.astro";
import './Registro.css';
---

<MainLayout title="Registro | Aventuras Paceñas">
    <div class="reg-root">
        <div class="reg-split-container">

            <div class="reg-image-pane">
                <div class="bg-image"></div>
                <div class="bg-overlay"></div>
                
                <div class="brand-content">
                    <img src="/images/logo.png" alt="Logo Aventuras Paceñas" class="pane-logo" />
                    <div class="badge-adventure">ÚNETE A LA AVENTURA</div>
                    <h1>Crea tu Cuenta</h1>
                    <p>Accede a experiencias únicas en La Paz. Rutas, guías y destinos andinos te esperan.</p>
                </div>
            </div>

            <div class="reg-form-pane">
                <div class="form-wrapper">

                    <div class="form-header">
                        <img src="/images/logo.png" alt="Logo Aventuras Paceñas" class="mobile-logo" />
                        <h1>Crear Cuenta</h1>
                        <p class="welcome-text">
                            Únete al portal principal de <strong>Aventuras Paceñas</strong>. 
                            Completa tus datos para acceder a rutas, guías y destinos andinos exclusivos.
                        </p>
                    </div>

                    <div id="error-msg" class="error-msg"></div>

                    <form id="reg-form" class="reg-form" novalidate>

                        <div class="field full">
                            <label for="nombres">Nombres <span class="required">*</span></label>
                            <div class="input-wrapper">
                                <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                                <input type="text" id="nombres" name="nombres" placeholder="Tus nombres" required autocomplete="given-name" />
                            </div>
                            <span class="field-error" id="err-nombres"></span>
                        </div>

                        <div class="field-row">
                            <div class="field">
                                <label for="ap-paterno">Apellido Paterno <span class="required">*</span></label>
                                <div class="input-wrapper">
                                    <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                                    <input type="text" id="ap-paterno" name="ap_paterno" placeholder="Apellido paterno" required autocomplete="family-name" />
                                </div>
                                <span class="field-error" id="err-ap-paterno"></span>
                            </div>
                            <div class="field">
                                <label for="ap-materno">Apellido Materno</label>
                                <div class="input-wrapper">
                                    <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                                    <input type="text" id="ap-materno" name="ap_materno" placeholder="Apellido materno" autocomplete="additional-name" />
                                </div>
                                <span class="field-error" id="err-ap-materno"></span>
                            </div>
                        </div>

                        <div class="field-row">
                            <div class="field">
                                <label for="telefono">Teléfono <span class="required">*</span></label>
                                <div class="input-wrapper">
                                    <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.32 2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 6 6l.81-.81a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                                    <input type="tel" id="telefono" name="telefono" placeholder="Ej: 76599447" required autocomplete="tel" />
                                </div>
                                <span class="field-error" id="err-telefono"></span>
                            </div>
                            <div class="field">
                                <label for="fecha-nac">Fecha de Nac. <span class="required">*</span></label>
                                <div class="input-wrapper">
                                    <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                                    <input type="date" id="fecha-nac" name="fecha_nacimiento" required />
                                </div>
                                <span class="field-error" id="err-fecha-nac"></span>
                            </div>
                        </div>

                        <div class="field full">
                            <label for="email">Correo Electrónico <span class="required">*</span></label>
                            <div class="input-wrapper">
                                <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                                <input type="email" id="email" name="email" placeholder="tu@correo.com" required autocomplete="email" />
                            </div>
                            <span class="field-error" id="err-email"></span>
                        </div>

                        <div class="field-row">
                            <div class="field">
                                <label for="password">Contraseña <span class="required">*</span></label>
                                <div class="input-wrapper">
                                    <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                                    <input type="password" id="password" name="password" placeholder="Mínimo 6" required autocomplete="new-password" />
                                    <button type="button" class="toggle-pw" data-target="password" tabindex="-1">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                                    </button>
                                </div>
                                <span class="field-error" id="err-password"></span>
                            </div>
                            <div class="field">
                                <label for="password2">Confirmar <span class="required">*</span></label>
                                <div class="input-wrapper">
                                    <svg class="input-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                                    <input type="password" id="password2" name="password2" placeholder="Repite" required autocomplete="new-password" />
                                    <button type="button" class="toggle-pw" data-target="password2" tabindex="-1">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                                    </button>
                                </div>
                                <span class="field-error" id="err-password2"></span>
                            </div>
                        </div>

                        <div class="terms-row">
                            <input type="checkbox" id="terminos" class="terms-check" required />
                            <label for="terminos" class="terms-label">
                                Acepto los <a href="#">Términos y Condiciones</a> y la
                                <a href="#">Política de Privacidad</a> de Aventuras Paceñas S.R.L.
                            </label>
                        </div>
                        <span class="field-error" id="err-terminos" style="margin-top:-10px; margin-bottom:15px; display:block; text-align:center;"></span>

                        <button type="submit" class="btn-primary" id="btn-submit">
                            <span id="btn-text">Crear mi Cuenta</span>
                            <svg id="btn-icon" class="btn-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                            <div class="spinner" id="btn-spinner" style="display:none"></div>
                        </button>

                    </form>

                    <div class="reg-footer">
                        <p>¿Ya tienes una cuenta?</p>
                        <a href="/login" class="btn-secondary">Iniciar Sesión →</a>
                        <div class="footer-copy">© 2026 Aventuras Paceñas.</div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</MainLayout>

<div class="modal-bg" id="reg-modal">
    <div class="modal-box">
        <div class="modal-icon">
            <img src="/images/logo.png" alt="Logo Aventuras Paceñas" style="height:80px;width:auto;border-radius:12px;" />
        </div>
        <h2 class="modal-title" style="color: var(--color-green); margin-bottom: 0.5rem;">¡Felicidades!</h2>
        <p class="modal-msg" style="font-size: 1.05rem; line-height: 1.5; color: var(--color-dark);">
            Tu cuenta ha sido creada exitosamente, <strong class="modal-name" id="modal-nombre"></strong>.<br /><br />
            Con esta misma cuenta ya puedes acceder tanto a nuestra plataforma web como a la <strong>App Móvil Wali</strong> para llevar a La Paz en tu bolsillo.
        </p>
<button type="button" class="modal-btn" id="btn-cerrar-modal" style="width: 100%; margin-top: 1rem; cursor: pointer; border: none; text-align: center; justify-content: center; display: flex; align-items: center;">Continuar</button>    </div>
</div>

<script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

<script is:inline>
const SB_URL = 'https://bimfxpcxnltubnpzqirs.supabase.co';
const SB_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJpbWZ4cGN4bmx0dWJucHpxaXJzIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzM5NjI2MTEsImV4cCI6MjA4OTUzODYxMX0.bWkii_XX_tuvyA10h7L_OpxxLPoaOfQkY8cisr9X2Y8';
const _sb = supabase.createClient(SB_URL, SB_KEY);

document.querySelectorAll('.toggle-pw').forEach(btn => {
    btn.addEventListener('click', () => {
        const input = document.getElementById(btn.dataset.target);
        input.type = input.type === 'password' ? 'text' : 'password';
    });
});

document.addEventListener('DOMContentLoaded', () => {
    const form      = document.getElementById('reg-form');
    const errorDiv  = document.getElementById('error-msg');
    const modal     = document.getElementById('reg-modal');
    const modalNm   = document.getElementById('modal-nombre');
    const btnSubmit = document.getElementById('btn-submit');
    const btnText   = document.getElementById('btn-text');
    const btnIcon   = document.getElementById('btn-icon');
    const spinner   = document.getElementById('btn-spinner');
    const btnCerrarModal = document.getElementById('btn-cerrar-modal');

    // === LÓGICA DEL BOTÓN DEL MODAL ===
    btnCerrarModal.addEventListener('click', () => {
        modal.classList.remove('open');
        // Redirige al usuario al inicio (o cambia '/' por la URL de tu dashboard si prefieres)
        window.location.href = '/'; 
    });

    // === REGLAS DE ENTRADA EN TIEMPO REAL ===
    // 1. Teléfono: Solo números, máximo 8 dígitos
    const telInput = document.getElementById('telefono');
    telInput.addEventListener('input', function() {
        this.value = this.value.replace(/\D/g, ''); // Elimina todo lo que no sea número
        if (this.value.length > 8) {
            this.value = this.value.slice(0, 8);
        }
    });

    // 2. Nombres y Apellidos: Solo letras y espacios
    const textFields = ['nombres', 'ap-paterno', 'ap-materno'];
    textFields.forEach(id => {
        document.getElementById(id).addEventListener('input', function() {
            this.value = this.value.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑ\s]/g, '');
        });
    });

    // Función para mostrar errores en línea
    function setFieldError(inputId, message) {
        const inputWrapper = document.getElementById(inputId).closest('.input-wrapper');
        const errorSpan = document.getElementById(`err-${inputId}`);
        
        if (message) {
            if(inputWrapper) inputWrapper.style.borderColor = '#d32f2f'; // Borde rojo
            errorSpan.textContent = message;
            errorSpan.style.display = 'block';
            errorSpan.style.color = '#d32f2f';
            errorSpan.style.fontSize = '0.8rem';
            errorSpan.style.marginTop = '4px';
        } else {
            if(inputWrapper) inputWrapper.style.borderColor = ''; // Restaura el borde original
            errorSpan.style.display = 'none';
        }
    }

    // Función para limpiar todos los errores
    function clearAllErrors() {
        errorDiv.style.display = 'none';
        document.querySelectorAll('.field-error').forEach(span => span.style.display = 'none');
        document.querySelectorAll('.input-wrapper').forEach(wrapper => wrapper.style.borderColor = '');
        document.getElementById('err-terminos').style.display = 'none';
    }

    function showError(msg) {
        errorDiv.textContent = msg;
        errorDiv.style.display = 'block';
        errorDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
        setTimeout(() => { errorDiv.style.display = 'none'; }, 7000);
    }

    function setLoading(val) {
        btnSubmit.disabled = val;
        btnText.textContent = val ? 'Creando cuenta...' : 'Crear mi Cuenta';
        btnIcon.style.display = val ? 'none' : 'inline';
        spinner.style.display = val ? 'inline-block' : 'none';
    }

    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        clearAllErrors();
        let hasErrors = false;

        const nombres  = form.nombres.value.trim();
        const apPat    = form.ap_paterno.value.trim();
        const apMat    = form.ap_materno.value.trim();
        const telefono = form.telefono.value.trim();
        const fechaNac = form.fecha_nacimiento.value;
        const email    = form.email.value.trim();
        const pass     = form.password.value;
        const pass2    = form.password2.value;
        const terminos = form.terminos.checked;

        // === VALIDACIONES AL ENVIAR ===
        if (!nombres) { setFieldError('nombres', 'Este campo es obligatorio.'); hasErrors = true; }
        if (!apPat) { setFieldError('ap-paterno', 'Este campo es obligatorio.'); hasErrors = true; }
        
        if (!telefono) { 
            setFieldError('telefono', 'Este campo es obligatorio.'); 
            hasErrors = true; 
        } else if (telefono.length !== 8) {
            setFieldError('telefono', 'El teléfono debe tener exactamente 8 dígitos.'); 
            hasErrors = true; 
        }

        if (!fechaNac) { setFieldError('fecha-nac', 'Selecciona tu fecha de nacimiento.'); hasErrors = true; }
        
        // Validación de formato de correo
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        if (!email) {
            setFieldError('email', 'Este campo es obligatorio.');
            hasErrors = true;
        } else if (!emailRegex.test(email)) {
            setFieldError('email', 'Ingresa un correo electrónico válido.');
            hasErrors = true;
        }

        if (!pass) {
            setFieldError('password', 'Este campo es obligatorio.');
            hasErrors = true;
        } else if (pass.length < 6) {
            setFieldError('password', 'La contraseña debe tener al menos 6 caracteres.');
            hasErrors = true;
        }

        if (!pass2) {
            setFieldError('password2', 'Confirma tu contraseña.');
            hasErrors = true;
        } else if (pass !== pass2) {
            setFieldError('password2', 'Las contraseñas no coinciden.');
            hasErrors = true;
        }

        if (!terminos) {
            const errTerm = document.getElementById('err-terminos');
            errTerm.textContent = 'Debes aceptar los Términos y Condiciones.';
            errTerm.style.display = 'block';
            errTerm.style.color = '#d32f2f';
            hasErrors = true;
        }

        if (hasErrors) return; // Detiene el envío si hay errores

        setLoading(true);

        try {
            const { data: authData, error: authErr } = await _sb.auth.signUp({ email, password: pass });

            if (authErr) {
                showError('Error al crear la cuenta: ' + authErr.message);
                setLoading(false);
                return;
            }

            const userId = authData?.user?.id;
            if (!userId) {
                showError('Error inesperado. Inténtalo de nuevo.');
                setLoading(false);
                return;
            }

            const { error: personaErr } = await _sb.from('personas').insert({
                id_usuario:       userId,
                nombres:          nombres,
                apellido_paterno: apPat,
                apellido_materno: apMat || null,
                telefono:         telefono,
                fecha_nacimiento: fechaNac,
                estado:           true,
                id_rol:           1,
            });

            if (personaErr) {
                showError('Error al guardar el perfil: ' + personaErr.message);
                setLoading(false);
                return;
            }

            // Muestra el modal si todo fue exitoso
            modalNm.textContent = nombres;
            modal.classList.add('open');

        } catch (err) {
            console.error(err);
            showError('Error de conexión. Verifica tu internet e inténtalo de nuevo.');
            setLoading(false);
        }
    });
});
</script>