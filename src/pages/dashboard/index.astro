---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import Sidebar from "../../components/dashboard/Sidebar.astro";
import Inicio from "../../components/dashboard/Inicio.astro";
import Usuarios from "../../components/dashboard/Usuarios.astro";
import Audios from "../../components/dashboard/Audios.astro";
import Rutas from "../../components/dashboard/Rutas.astro";
import RAGContext from "../../components/dashboard/RAGContext.astro";
---

<DashboardLayout title="Tourism Dashboard">
  <Sidebar />

  <div class="dashboard-main">

    <!-- HEADER -->
    <header class="dashboard-header">
      <div class="header-left">
        <div>
          <span class="header-breadcrumb" id="headerBreadcrumb">DASHBOARD</span>
          <h1 class="header-title" id="headerTitle">Inicio</h1>
          <span class="header-subtitle" id="headerSubtitle">Vista general del sistema turístico</span>
        </div>
      </div>
      <div class="header-right">
        <span class="header-tag">Panel de Administración</span>
      </div>
    </header>

    <!-- CONTENIDO PRINCIPAL -->
    <main class="dashboard-content">
      <Inicio />
      <Usuarios />
      <Audios />
      <Rutas />

      <!-- Sección Sitios (antes Mapas) -->
      <!-- data-section-target debe coincidir con data-section en Sidebar: "sitios" -->


      <RAGContext />

      <!-- Secciones placeholder para nuevos módulos -->
      <div data-section-target="seguridad" class="section">
        <div class="page-header">
          <h2 class="page-title">Seguridad</h2>
          <p class="page-subtitle">Control de acceso y gestión de permisos</p>
        </div>
        <div class="card">
          <div class="card-body" style="padding: 40px; text-align: center; color: var(--color-text-light);">
            Módulo de Seguridad — Próximamente
          </div>
        </div>
      </div>

      <div data-section-target="itinerarios" class="section">
        <div class="page-header">
          <h2 class="page-title">Itinerarios</h2>
          <p class="page-subtitle">Planificación y gestión de recorridos turísticos</p>
        </div>
        <div class="card">
          <div class="card-body" style="padding: 40px; text-align: center; color: var(--color-text-light);">
            Módulo de Itinerarios — Próximamente
          </div>
        </div>
      </div>

      <div data-section-target="configuracion" class="section">
        <div class="page-header">
          <h2 class="page-title">Configuración</h2>
          <p class="page-subtitle">Ajustes generales del sistema</p>
        </div>
        <div class="card">
          <div class="card-body" style="padding: 40px; text-align: center; color: var(--color-text-light);">
            Módulo de Configuración — Próximamente
          </div>
        </div>
      </div>
    </main>

    <!-- FOOTER -->
    <footer class="dashboard-footer">
      <p class="footer-text">© 2026 Aventuras Paceñas — Todos los derechos reservados</p>
    </footer>

  </div>

  <script>
    import { supabase } from "../../lib/supabase";

    const checkAdmin = async () => {
      const loading = document.getElementById("loading-overlay");
      const container = document.getElementById("dashboard-container");

      const { data: { session } } = await supabase.auth.getSession();

      if (!session) {
        window.location.href = "/login";
        return;
      }

      const { data: persona } = await supabase
        .from("personas")
        .select("id_rol")
        .eq("id_usuario", session.user.id)
        .maybeSingle();

      if (persona && Number(persona.id_rol) === 2) {
        if (loading) loading.style.display = "none";
        if (container) container.style.setProperty("display", "flex", "important");
      } else {
        alert("Acceso restringido: No tienes permisos de Administrador.");
        window.location.href = "/";
      }
    };

    checkAdmin();
    document.addEventListener("astro:page-load", checkAdmin);
  </script>
</DashboardLayout>