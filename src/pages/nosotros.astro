---
import MainLayout from "../layouts/MainLayout.astro";
import NosotrosContent from "../components/Nosotros.astro";
import '../components/Inicio.css';
---

<MainLayout title="Nosotros | Agencia de Turismo">
  <div class="inicio-root">
    
    <section class="hero" style="height: 60vh;">
      <div class="hero-slides">
        <div class="hero-slide active" style="background-image: url('/images/centro_historico.jpg')"></div>
      </div>
      <div class="hero-overlay"></div>
      <div class="hero-inner">
        <div class="reveal">
          <div class="badge"><span class="bdot"></span> Bienvenida</div>
          <h1 class="hero-title">Somos el futuro del<br /><em>Turismo Paceño</em></h1>
          <p class="hero-sub">Tecnología, cultura y aventura en un solo lugar.</p>
        </div>
      </div>
    </section>

    <NosotrosContent />

  </div>
</MainLayout>